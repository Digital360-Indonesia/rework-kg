---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Related posts (same category, exclude current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);

const coverFor = (slug: string, image?: string) =>
  image || '/images/placeholder/sample-section3a.webp';

const readingTime = (body?: string) =>
  Math.max(1, Math.round((body?.split(/\s+/).filter(Boolean).length || 0) / 200));

const fmtDate = (d: Date) => d.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });

const cover = coverFor(post.slug, post.data.image);
const rt = readingTime(post.body);
const wa = 'https://wa.me/6285117049918?text=' + encodeURIComponent('Halo Kustom Garment, saya mau bikin custom apparel.');

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kustomgarment.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://kustomgarment.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title },
  ]
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={cover}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={(post.data.lastMod || post.data.pubDate).toISOString()}
>
  <script set:html={JSON.stringify(breadcrumbSchema)} type="application/ld+json" />
  <main class="ar">
    <article class="ar-wrap">
      <!-- Header -->
      <header class="ar-head">
        <a class="ar-back" href="/blog/"><span aria-hidden="true">←</span> Semua artikel</a>
        <span class="ar-cat reveal">{post.data.category}</span>
        <h1 class="ar-title reveal">{post.data.title}</h1>
        <div class="ar-meta reveal">
          <span>{post.data.author}</span>
          <span class="ar-dot" aria-hidden="true">·</span>
          <span>{fmtDate(post.data.pubDate)}</span>
          <span class="ar-dot" aria-hidden="true">·</span>
          <span>{rt} menit baca</span>
        </div>
      </header>

      <!-- Feature image -->
      <div class="ar-feature reveal">
        <img src={cover} alt={post.data.title} loading="eager" width="1200" height="800" />
      </div>

      <!-- Body -->
      <div class="ar-body">
        <Content />
      </div>

      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="ar-tags">
          {post.data.tags.map(tag => (<span class="ar-tag">{tag}</span>))}
        </div>
      )}

      <!-- End CTA -->
      <div class="ar-cta-box">
        <p class="ar-cta-lead">Mau bikin custom-mu sendiri?</p>
        <a class="ar-cta" href={wa} target="_blank" rel="noopener noreferrer">
          Mulai dari sini <span aria-hidden="true">→</span>
        </a>
      </div>
    </article>

    <!-- Related -->
    {relatedPosts.length > 0 && (
      <section class="ar-related">
        <div class="ar-related-wrap">
          <h2 class="ar-related-title reveal">Baca juga</h2>
          <div class="ar-rel-grid">
            {relatedPosts.map((rp, i) => (
              <a class="bl-card reveal" style={`transition-delay:${i * 80}ms`} href={`/blog/${rp.slug}/`}>
                <div class="bl-card-frame">
                  <img src={coverFor(rp.slug, rp.data.image)} alt={rp.data.title} loading="lazy" />
                </div>
                <span class="bl-cat">{rp.data.category}</span>
                <h3 class="bl-card-title">{rp.data.title}</h3>
                <p class="bl-card-desc">{rp.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .ar { background: #ffffff; }
  .ar-wrap { max-width: 44rem; margin: 0 auto; padding: 3.5rem 1.5rem 0; }
  @media (min-width: 1024px) { .ar-wrap { padding: 5rem 1.5rem 0; } }

  /* Header */
  .ar-head { margin-bottom: 2rem; }
  .ar-back {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-sans); font-weight: 700; font-size: 0.875rem; color: #6b7280;
    text-decoration: none; margin-bottom: 2rem; transition: color 200ms ease;
  }
  .ar-back span { transition: transform 280ms cubic-bezier(0.19,1,0.22,1); }
  @media (hover: hover) { .ar-back:hover { color: #ff4c00; } .ar-back:hover span { transform: translateX(-4px); } }
  .ar-cat { display: block; font-family: var(--font-sans); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: #ff4c00; margin-bottom: 0.85rem; }
  .ar-title {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.08; letter-spacing: -0.025em;
    color: #1a1a1a; margin: 0 0 1.25rem;
  }
  .ar-meta { font-family: var(--font-sans); font-weight: 600; font-size: 0.875rem; color: #9ca3af; display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; }
  .ar-dot { color: #d1d5db; }

  /* Feature image */
  .ar-feature { border-radius: 1.5rem; overflow: hidden; aspect-ratio: 16 / 10; background: #f4f4f4; margin-bottom: 3rem; }
  .ar-feature img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Body / prose */
  .ar-body { font-family: var(--font-sans); font-weight: 600; color: #374151; font-size: 1.0625rem; line-height: 1.75; }
  .ar-body :global(h2) { font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.15; letter-spacing: -0.02em; color: #1a1a1a; margin: 2.5rem 0 1rem; }
  .ar-body :global(h3) { font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.25rem, 2.4vw, 1.5rem); line-height: 1.2; letter-spacing: -0.01em; color: #1a1a1a; margin: 2rem 0 0.75rem; }
  .ar-body :global(h4) { font-family: var(--font-sans); font-weight: 700; font-size: 1.125rem; color: #1a1a1a; margin: 1.5rem 0 0.5rem; }
  .ar-body :global(p) { margin: 0 0 1.25rem; }
  .ar-body :global(a) { color: #ff4c00; text-decoration: underline; text-underline-offset: 2px; }
  @media (hover: hover) { .ar-body :global(a:hover) { color: #d63e00; } }
  .ar-body :global(strong), .ar-body :global(b) { font-weight: 700; color: #1a1a1a; }
  .ar-body :global(ul), .ar-body :global(ol) { margin: 0 0 1.25rem; padding-left: 1.4rem; }
  .ar-body :global(li) { margin: 0.4rem 0; list-style-position: outside; }
  .ar-body :global(img) { border-radius: 1rem; margin: 1.5rem 0; }
  .ar-body :global(blockquote) {
    margin: 1.75rem 0; padding: 1.25rem 1.5rem; border-left: 4px solid #ff4c00;
    background: #faf9f8; border-radius: 0 0.75rem 0.75rem 0; color: #1a1a1a; font-size: 1.125rem;
  }
  .ar-body :global(blockquote p) { margin: 0; }
  .ar-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.75rem 0; font-size: 0.9375rem; display: block; overflow-x: auto; }
  .ar-body :global(thead th) { background: #ff4c00; color: #ffffff; font-weight: 700; text-align: left; padding: 0.8rem 1rem; white-space: nowrap; }
  .ar-body :global(tbody td), .ar-body :global(tbody th) { padding: 0.75rem 1rem; border-bottom: 1px solid #f0f0f0; font-weight: 600; color: #525252; white-space: nowrap; }
  .ar-body :global(tbody tr:nth-child(even)) { background: #fafafa; }
  .ar-body :global(hr) { border: none; border-top: 1px solid #ececec; margin: 2.5rem 0; }

  /* Tags */
  .ar-tags { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: 3rem 0 0; padding-top: 2.5rem; border-top: 1px solid #ececec; }
  .ar-tag { font-family: var(--font-sans); font-weight: 600; font-size: 0.8125rem; color: #6b7280; border: 1px solid #ececec; border-radius: 999px; padding: 0.4rem 0.9rem; }

  /* End CTA */
  .ar-cta-box { margin: 3rem 0 0; padding: 2.5rem; border-radius: 1.5rem; background: #f5f5f5; }
  .ar-cta-lead { font-family: var(--font-sans); font-weight: 600; font-size: 1rem; color: #6b7280; margin: 0 0 0.5rem; }
  .ar-cta {
    display: inline-flex; align-items: baseline; gap: 0.5rem; position: relative;
    font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em; color: #1a1a1a; text-decoration: none; padding-bottom: 0.12em;
  }
  .ar-cta span { color: #ff4c00; display: inline-block; transition: transform 320ms cubic-bezier(0.19,1,0.22,1); }
  .ar-cta::after { content: ''; position: absolute; left: 0; bottom: 0; width: 100%; height: 3px; background: #ff4c00; transform: scaleX(0); transform-origin: left; transition: transform 460ms cubic-bezier(0.19,1,0.22,1); }
  @media (hover: hover) { .ar-cta:hover::after { transform: scaleX(1); } .ar-cta:hover span { transform: translateX(8px); } }

  /* Related */
  .ar-related { padding: 4rem 0 6rem; }
  @media (min-width: 1024px) { .ar-related { padding: 5rem 0 8rem; } }
  .ar-related-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .ar-related-wrap { padding: 0 2.5rem; } }
  .ar-related-title { font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: #1a1a1a; margin: 0 0 2rem; }
  .ar-rel-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem 1.75rem; }
  @media (min-width: 640px) { .ar-rel-grid { grid-template-columns: repeat(3, 1fr); } }

  /* Shared blog card (matches blog/index.astro) */
  .bl-card { display: block; text-decoration: none; }
  .bl-card-frame { position: relative; border-radius: 1.25rem; overflow: hidden; aspect-ratio: 4 / 3; background: #f4f4f4; margin-bottom: 1.1rem; }
  .bl-card-frame img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 800ms cubic-bezier(0.19,1,0.22,1); }
  .bl-cat { font-family: var(--font-sans); font-weight: 700; font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase; color: #ff4c00; }
  .bl-card-title { font-family: var(--font-sans); font-weight: 700; font-size: 1.25rem; line-height: 1.25; letter-spacing: -0.01em; color: #1a1a1a; margin: 0.55rem 0 0.5rem; transition: color 220ms ease; }
  .bl-card-desc { font-family: var(--font-sans); font-weight: 600; font-size: 0.9375rem; line-height: 1.55; color: #6b7280; margin: 0; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-clamp: 2; overflow: hidden; }
  @media (hover: hover) {
    .bl-card:hover .bl-card-frame img { transform: scale(1.06); }
    .bl-card:hover .bl-card-title { color: #ff4c00; }
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .bl-card-frame img { transition: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
