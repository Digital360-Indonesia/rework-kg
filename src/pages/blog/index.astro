---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const byDate = (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
const featured = allPosts.filter(p => p.data.featured).sort(byDate);
const editorial = allPosts.filter(p => !p.data.featured && p.data.category !== 'Recommendation').sort(byDate);
const recommendation = allPosts.filter(p => !p.data.featured && p.data.category === 'Recommendation').sort(byDate);
const posts = [...featured, ...editorial, ...recommendation];

const coverFor = (slug: string, image?: string) =>
  image || '/images/placeholder/sample-section3a.webp';

const readingTime = (body?: string) =>
  Math.max(1, Math.round((body?.split(/\s+/).filter(Boolean).length || 0) / 200));

const fmtDate = (d: Date) => d.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });

const hero = {
  eyebrow: 'Blog',
  titleLead: 'Tips, bahan',
  titleAccent: '& cerita custom.',
  sub: 'Bahan kain, panduan ukuran, sampai tren apparel — biar kamu makin paham sebelum bikin.',
};

const SHOW = 9;
const BATCH = 9;
---

<BaseLayout title="Blog — Tips & Panduan Custom Apparel | Kustom Garment" description="Artikel dan tips seputar konveksi, bahan kain, dan panduan ukuran dari Kustom Garment.">
  <main class="bl">
    <!-- HERO -->
    <section class="bl-hero">
      <div class="bl-wrap">
        <span class="bl-eyebrow reveal">{hero.eyebrow}</span>
        <h1 class="bl-hero-title reveal">{hero.titleLead} <span class="bl-hero-accent">{hero.titleAccent}</span></h1>
        <p class="bl-hero-sub reveal">{hero.sub}</p>
      </div>
    </section>

    <!-- POSTS GRID -->
    <section class="bl-list">
      <div class="bl-wrap">
        <div class="bl-grid" id="blog-grid">
          {posts.map((post, i) => (
            <a class:list={['bl-card', 'reveal', { 'bl-hidden': i >= SHOW }]}
               data-i={i}
               style={`transition-delay:${(i % 3) * 80}ms`}
               href={`/blog/${post.slug}/`}>
              <div class="bl-card-frame">
                <img src={coverFor(post.slug, post.data.image)} alt={post.data.title} loading={i < 3 ? 'eager' : 'lazy'} />
                {post.data.featured && <span class="bl-flag">Featured</span>}
              </div>
              <span class="bl-cat">{post.data.category}</span>
              <h2 class="bl-card-title">{post.data.title}</h2>
              <p class="bl-card-desc">{post.data.description}</p>
              <div class="bl-meta">
                <span>{fmtDate(post.data.pubDate)}</span>
                <span class="bl-dot" aria-hidden="true">·</span>
                <span>{readingTime(post.body)} menit baca</span>
              </div>
            </a>
          ))}
        </div>

        <!-- Skeleton loader -->
        <div class="bl-grid bl-skeleton-grid" id="skeleton-grid" aria-hidden="true" style="display:none;">
          {Array.from({ length: BATCH }).map(() => (
            <div class="bl-skel-card">
              <div class="bl-skel-frame shimmer"></div>
              <div class="bl-skel-cat shimmer"></div>
              <div class="bl-skel-title shimmer"></div>
              <div class="bl-skel-desc shimmer"></div>
              <div class="bl-skel-meta shimmer"></div>
            </div>
          ))}
        </div>

        {posts.length > SHOW && (
          <div class="bl-loadmore" id="loadmore-wrap">
            <button class="bl-loadmore-btn" id="loadmore-btn">
              Lihat lebih banyak
              <span class="bl-loadmore-count" id="remaining-count">
                ({posts.length - SHOW} artikel lagi)
              </span>
            </button>
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .bl { background: #ffffff; }
  .bl-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .bl-wrap { padding: 0 2.5rem; } }

  /* HERO */
  .bl-hero { background: #ff4c00; color: #ffffff; padding: 5.5rem 0 6rem; text-align: center; overflow: hidden; }
  @media (min-width: 1024px) { .bl-hero { padding: 8rem 0 8.5rem; } }
  .bl-eyebrow {
    display: inline-block; font-family: var(--font-sans); font-weight: 700;
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); margin-bottom: 1.5rem;
  }
  .bl-hero-title {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.25rem); line-height: 1.02; letter-spacing: -0.03em;
    margin: 0 auto 1.5rem; color: #ffffff; max-width: 18ch;
  }
  .bl-hero-accent { color: #ff4c00; -webkit-text-stroke: 2px #ffffff; text-stroke: 2px #ffffff; }
  .bl-hero-sub {
    font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(1rem, 1.6vw, 1.25rem); line-height: 1.55;
    color: rgba(255,255,255,0.92); max-width: 40rem; margin: 0 auto;
  }

  /* LIST section */
  .bl-list { padding: 4rem 0 6rem; }
  @media (min-width: 1024px) { .bl-list { padding: 6rem 0 8rem; } }

  /* LOAD MORE */
  .bl-loadmore {
    display: flex;
    justify-content: center;
    padding-top: 3rem;
  }
  .bl-loadmore-btn {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    background: #f5f5f5;
    border: 2px solid #e8e8e8;
    border-radius: 999px;
    padding: 1rem 2.5rem;
    cursor: pointer;
    transition: all 250ms ease;
  }
  .bl-loadmore-btn:hover {
    color: #ff4c00;
    border-color: #ff4c00;
    background: #fff8f5;
  }
  .bl-loadmore-btn:active {
    transform: scale(0.97);
  }
  .bl-loadmore-btn:disabled {
    opacity: 0.6;
    pointer-events: none;
  }
  .bl-loadmore-count {
    font-weight: 600;
    font-size: 0.8125rem;
    color: #9ca3af;
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .bl-card-frame img { transition: none; }
  }
</style>

<!-- is:global because Astro scoped styles use data-astro-cid-* which doesn't apply
     to elements whose classes are toggled dynamically -->
<style is:global>
  /* GRID */
  .bl .bl-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem 1.75rem; }
  @media (min-width: 640px) { .bl .bl-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .bl .bl-grid { grid-template-columns: repeat(3, 1fr); } }

  /* CARD */
  .bl .bl-card { display: block; text-decoration: none; }
  .bl .bl-card-frame {
    position: relative; border-radius: 1.25rem; overflow: hidden;
    aspect-ratio: 4 / 3; background: #f4f4f4; margin-bottom: 1.1rem;
  }
  .bl .bl-card-frame img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 800ms cubic-bezier(0.19,1,0.22,1);
  }
  .bl .bl-flag {
    position: absolute; top: 0.85rem; left: 0.85rem;
    font-family: var(--font-sans); font-weight: 700; font-size: 0.6875rem;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: #ffffff; background: #ff4c00; border-radius: 999px; padding: 0.3rem 0.7rem;
  }
  .bl .bl-cat {
    font-family: var(--font-sans); font-weight: 700; font-size: 0.6875rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: #ff4c00;
  }
  .bl .bl-card-title {
    font-family: var(--font-sans); font-weight: 700; font-size: 1.25rem;
    line-height: 1.25; letter-spacing: -0.01em;
    color: #1a1a1a; margin: 0.55rem 0 0.5rem; transition: color 220ms ease;
  }
  .bl .bl-card-desc {
    font-family: var(--font-sans); font-weight: 600; font-size: 0.9375rem;
    line-height: 1.55; color: #6b7280; margin: 0;
    display: -webkit-box; -webkit-box-orient: vertical;
    -webkit-line-clamp: 2; line-clamp: 2; overflow: hidden;
  }
  .bl .bl-meta {
    font-family: var(--font-sans); font-weight: 600; font-size: 0.8125rem;
    color: #9ca3af; margin-top: 0.9rem; display: flex;
    align-items: center; gap: 0.5rem;
  }
  .bl .bl-dot { color: #d1d5db; }
  @media (hover: hover) {
    .bl .bl-card:hover .bl-card-frame img { transform: scale(1.06); }
    .bl .bl-card:hover .bl-card-title { color: #ff4c00; }
  }

  /* HIDDEN CARDS — SEO crawlable but visually hidden */
  .bl .bl-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* SKELETON */
  .bl .shimmer {
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 37%, #f0f0f0 63%);
    background-size: 200% 100%;
    animation: bl-shimmer 1.4s ease-in-out infinite;
    border-radius: 0.5rem;
  }
  @keyframes bl-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  .bl .bl-skel-card { display: block; }
  .bl .bl-skel-frame { aspect-ratio: 4 / 3; border-radius: 1.25rem; margin-bottom: 1.1rem; }
  .bl .bl-skel-cat { height: 0.75rem; width: 5rem; margin-bottom: 0.55rem; }
  .bl .bl-skel-title { height: 1.5rem; width: 85%; margin-bottom: 0.5rem; border-radius: 0.35rem; }
  .bl .bl-skel-desc { height: 2.5rem; width: 100%; margin-bottom: 0.9rem; border-radius: 0.35rem; }
  .bl .bl-skel-meta { height: 0.8125rem; width: 10rem; }

  /* Card reveal animation */
  .bl .bl-card-enter {
    animation: bl-card-fade-in 500ms cubic-bezier(0.19,1,0.22,1) forwards;
  }
  @keyframes bl-card-fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script define:vars={{ SHOW, BATCH, total: posts.length }}>
  // Reveal observer
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Load More
  const btn = document.getElementById('loadmore-btn');
  const remainingEl = document.getElementById('remaining-count');
  const wrap = document.getElementById('loadmore-wrap');
  const skeleton = document.getElementById('skeleton-grid');
  if (!btn) return;

  let shown = SHOW;

  btn.addEventListener('click', () => {
    btn.disabled = true;
    skeleton.style.display = 'grid';
    skeleton.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    setTimeout(() => {
      skeleton.style.display = 'none';
      const hidden = document.querySelectorAll('.bl-hidden');
      let count = 0;

      hidden.forEach((card) => {
        if (count < BATCH) {
          card.classList.remove('bl-hidden', 'reveal');
          card.classList.add('bl-card-enter');
          card.style.opacity = '1';
          card.style.transform = 'none';
          count++;
        }
      });

      shown += count;
      const left = total - shown;
      if (left <= 0) {
        wrap.style.display = 'none';
      } else {
        remainingEl.textContent = `(${left} artikel lagi)`;
      }
      btn.disabled = false;
    }, 400);
  });
</script>
