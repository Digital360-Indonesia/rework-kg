---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = sortedPosts.filter(post => post.data.featured);
const regularPosts = sortedPosts.filter(post => !post.data.featured);
const posts = [...featuredPosts, ...regularPosts];

// Blog featured images aren't migrated yet (/images/blog/* is missing). Map each post to a
// real existing image so cards never render broken. Swap back to post.data.image once real
// featured images land under /images/blog/.
const fallbackPool = [
  '/images/placeholder/theme-image-1777040341996.png',
  '/images/placeholder/theme-image-1777126525887.png',
  '/images/placeholder/theme-image-1777126637504.png',
  '/images/placeholder/theme-image-1777385298306.png',
  '/images/placeholder/sample-section3a.webp',
  '/images/placeholder/sample-section3b.webp',
  '/images/placeholder/sample-section3c.webp',
  '/images/placeholder/sample-section3d.webp',
  '/images/categories/business.webp',
  '/images/categories/community.webp',
  '/images/categories/campus.webp',
  '/images/categories/personal.webp',
];
const coverFor = (slug: string) =>
  fallbackPool[[...slug].reduce((a, c) => a + c.charCodeAt(0), 0) % fallbackPool.length];

const readingTime = (body?: string) =>
  Math.max(1, Math.round((body?.split(/\s+/).filter(Boolean).length || 0) / 200));

const fmtDate = (d: Date) => d.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });

const hero = {
  eyebrow: 'Blog',
  titleLead: 'Tips, bahan',
  titleAccent: '& cerita custom.',
  sub: 'Bahan kain, panduan ukuran, sampai tren apparel — biar kamu makin paham sebelum bikin.',
};
---

<BaseLayout title="Blog — Tips & Panduan Custom Apparel | Kustom Garment" description="Artikel dan tips seputar konveksi, bahan kain, dan panduan ukuran dari Kustom Garment.">
  <main class="bl">
    <!-- HERO (orange, centered) -->
    <section class="bl-hero">
      <div class="bl-wrap">
        <span class="bl-eyebrow reveal">{hero.eyebrow}</span>
        <h1 class="bl-hero-title reveal">{hero.titleLead} <span class="bl-hero-accent">{hero.titleAccent}</span></h1>
        <p class="bl-hero-sub reveal">{hero.sub}</p>
      </div>
    </section>

    <!-- POSTS GRID -->
    <section class="bl-list">
      <div class="bl-wrap">
        <div class="bl-grid">
          {posts.map((post, i) => (
            <a class="bl-card reveal" style={`transition-delay:${(i % 3) * 80}ms`} href={`/blog/${post.slug}/`}>
              <div class="bl-card-frame">
                <img src={coverFor(post.slug)} alt={post.data.title} loading="lazy" />
                {post.data.featured && <span class="bl-flag">Featured</span>}
              </div>
              <span class="bl-cat">{post.data.category}</span>
              <h2 class="bl-card-title">{post.data.title}</h2>
              <p class="bl-card-desc">{post.data.description}</p>
              <div class="bl-meta">
                <span>{fmtDate(post.data.pubDate)}</span>
                <span class="bl-dot" aria-hidden="true">·</span>
                <span>{readingTime(post.body)} menit baca</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .bl { background: #ffffff; }
  .bl-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .bl-wrap { padding: 0 2.5rem; } }

  /* HERO */
  .bl-hero { background: #ff4c00; color: #ffffff; padding: 5.5rem 0 6rem; text-align: center; overflow: hidden; }
  @media (min-width: 1024px) { .bl-hero { padding: 8rem 0 8.5rem; } }
  .bl-eyebrow {
    display: inline-block; font-family: var(--font-sans); font-weight: 700;
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); margin-bottom: 1.5rem;
  }
  .bl-hero-title {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.25rem); line-height: 1.02; letter-spacing: -0.03em;
    margin: 0 auto 1.5rem; color: #ffffff; max-width: 18ch;
  }
  .bl-hero-accent { color: #ff4c00; -webkit-text-stroke: 2px #ffffff; text-stroke: 2px #ffffff; }
  .bl-hero-sub {
    font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(1rem, 1.6vw, 1.25rem); line-height: 1.55;
    color: rgba(255,255,255,0.92); max-width: 40rem; margin: 0 auto;
  }

  /* LIST */
  .bl-list { padding: 4rem 0 6rem; }
  @media (min-width: 1024px) { .bl-list { padding: 6rem 0 8rem; } }
  .bl-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem 1.75rem; }
  @media (min-width: 640px) { .bl-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .bl-grid { grid-template-columns: repeat(3, 1fr); } }

  .bl-card { display: block; text-decoration: none; }
  .bl-card-frame {
    position: relative; border-radius: 1.25rem; overflow: hidden;
    aspect-ratio: 4 / 3; background: #f4f4f4; margin-bottom: 1.1rem;
  }
  .bl-card-frame img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 800ms cubic-bezier(0.19,1,0.22,1); }
  .bl-flag {
    position: absolute; top: 0.85rem; left: 0.85rem;
    font-family: var(--font-sans); font-weight: 700; font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: #ffffff; background: #ff4c00; border-radius: 999px; padding: 0.3rem 0.7rem;
  }
  .bl-cat { font-family: var(--font-sans); font-weight: 700; font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase; color: #ff4c00; }
  .bl-card-title {
    font-family: var(--font-sans); font-weight: 700; font-size: 1.25rem; line-height: 1.25; letter-spacing: -0.01em;
    color: #1a1a1a; margin: 0.55rem 0 0.5rem; transition: color 220ms ease;
  }
  .bl-card-desc {
    font-family: var(--font-sans); font-weight: 600; font-size: 0.9375rem; line-height: 1.55; color: #6b7280; margin: 0;
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-clamp: 2; overflow: hidden;
  }
  .bl-meta { font-family: var(--font-sans); font-weight: 600; font-size: 0.8125rem; color: #9ca3af; margin-top: 0.9rem; display: flex; align-items: center; gap: 0.5rem; }
  .bl-dot { color: #d1d5db; }
  @media (hover: hover) {
    .bl-card:hover .bl-card-frame img { transform: scale(1.06); }
    .bl-card:hover .bl-card-title { color: #ff4c00; }
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .bl-card-frame img { transition: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
