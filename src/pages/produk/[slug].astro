---
import BaseLayout from '../../layouts/BaseLayout.astro';
import catalog from '../../data/products/catalog.json';
import siteConfig from '../../data/site-config.json';

export function getStaticPaths() {
  return catalog.archetypes.map((a) => ({ params: { slug: a.slug }, props: { product: a } }));
}

const { product } = Astro.props;
const rp = (n: number) => 'Rp ' + new Intl.NumberFormat('id-ID').format(n);
const priceRange = `${rp(product.price_min)} – ${rp(product.price_max)}`;
const defaultFabric = catalog.fabrics.find((f) => f.id === product.default_fabric);
// only garment types with a defined garment_types entry have the online customizer (v1: kemeja)
const hasCustomizer = catalog.garment_types.some((g) => g.id === product.garment_type);

const waBase = (siteConfig as any)?.contact?.whatsappUrl || 'https://wa.me/6285161202499';
const waHref = `${waBase}?text=${encodeURIComponent(`Halo Kustom Garment, saya tertarik dengan ${product.name}. Boleh info lebih lanjut?`)}`;

const metaTitle = `${product.name} | Kustom Garment`;
const metaDescription = product.positioning;
const lockedSpec = Object.entries(product.locked_spec) as [string, string][];

// "Style Mode" position on the Kasual → Formal axis (0-100), per archetype, derived from spec §6 positioning
const STYLE_MODE: Record<string, number> = {
  'boardroom-shirt': 80, 'launching-shirt': 90, 'field-operation-shirt': 25, 'service-shirt': 35,
  'crew-field-shirt': 25, 'campus-drill-workshirt': 30, 'standard-issue-workshirt': 60,
  'office-polo': 55, 'heavyweight-field-polo': 30, 'pique-student-polo': 35,
  'brand-merch-tee': 20, 'the-event-tee': 15, 'combed-class-tee': 15,
  'office-bomber': 55, 'corporate-drill-jacket': 40, 'event-windbreaker': 35,
  'varsity-classic': 55, 'trail-windbreaker': 25, 'fleece-varsity': 50,
  'field-utility-vest': 25, 'fleece-vest': 45, 'standard-issue-vest': 60,
  'industrial-wearpack': 20,
};
const styleModeVal = STYLE_MODE[product.slug] ?? 50;

// related products from the same segment (cap at 4)
const related = (catalog.archetypes as any[])
  .filter((a) => a.segment === product.segment && a.slug !== product.slug)
  .slice(0, 4);
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <section class="pdp">
    <div class="pdp-grid">
      <!-- Gallery: thumbnail rail + main preview -->
      <div class="pdp-gallery">
        <div class="pdp-thumbs" role="list">
          {product.gallery.map((src: string, i: number) => (
            <button class:list={['pdp-thumb', { active: i === 0 }]} data-src={src} aria-label={`Lihat gambar ${i + 1}`}>
              <img src={src} alt="" loading="lazy" />
            </button>
          ))}
        </div>
        <div class="pdp-main">
          {product.badge && <span class="pdp-badge">{product.badge}</span>}
          <img id="pdp-main-img" src={product.gallery[0]} alt={product.name} />
        </div>
      </div>

      <!-- Right rail -->
      <div class="pdp-rail">
        <h1 class="pdp-title">{product.name}</h1>

        <div class="pdp-rating" aria-label={`Rating ${product.rating} dari 5`}>
          <span class="pdp-stars" aria-hidden="true">★★★★★</span>
          <span class="pdp-reviews">({product.reviews})</span>
        </div>

        <div class="pdp-price">
          {priceRange}
          <span class="pdp-price-note">{product.price_note}</span>
        </div>

        <div class="pdp-actions">
          <a class="pdp-btn pdp-btn-wa" href={waHref} target="_blank" rel="noopener noreferrer">Hubungi via WhatsApp</a>
          {hasCustomizer
            ? <a class="pdp-btn pdp-btn-custom" href={`/produk/${product.slug}/custom`}>Custom Sekarang</a>
            : <a class="pdp-btn pdp-btn-custom" href={waHref} target="_blank" rel="noopener noreferrer">Kustom via WhatsApp</a>}
        </div>
        <p class="pdp-reassure">Tanpa minimum order · Desain dibantu gratis · Made-by-order</p>

        <div class="pdp-acc">
          <details open>
            <summary>Description<span class="chev" aria-hidden="true"></span></summary>
            <div class="pdp-acc-body"><p>{product.description}</p></div>
          </details>
          <details>
            <summary>Design<span class="chev" aria-hidden="true"></span></summary>
            <div class="pdp-acc-body">
              <ul class="pdp-spec">
                {lockedSpec.map(([k, v]) => (
                  <li><span class="pdp-spec-k">{k}</span><span class="pdp-spec-v">{v}</span></li>
                ))}
              </ul>
              <p class="pdp-acc-hint">Mau collar / cuff / pocket beda? Bahas langsung via WhatsApp.</p>
            </div>
          </details>
          <details>
            <summary>Fabric &amp; Care<span class="chev" aria-hidden="true"></span></summary>
            <div class="pdp-acc-body">
              {defaultFabric && <p><strong>{defaultFabric.name}</strong> — {defaultFabric.description}</p>}
              <p>{product.care}</p>
            </div>
          </details>
        </div>

        <div class="pdp-card pdp-feel">
          <h3 class="pdp-card-h">How It Feels</h3>
          <div class="pdp-feel-label">Style Mode</div>
          <div class="pdp-feel-bar"><span class="pdp-feel-bar-fill" style={`width:${styleModeVal}%`}></span></div>
          <div class="pdp-feel-ends"><span>Kasual</span><span>Formal</span></div>
        </div>
        {defaultFabric && (
          <div class="pdp-card pdp-fabric">
            <h3 class="pdp-card-h">Fabric / Material</h3>
            <div class="pdp-fabric-img"><img src={defaultFabric.swatch_image} alt={defaultFabric.name} loading="lazy" /></div>
            <div class="pdp-fabric-name">{defaultFabric.name}</div>
            <p class="pdp-fabric-desc">{defaultFabric.description}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="pdp-rec">
      <div class="pdp-rec-wrap">
        <h2 class="pdp-rec-h">Lihat juga</h2>
        <div class="pdp-rec-grid">
          {related.map((r) => (
            <a class="pdp-rec-card" href={`/produk/${r.slug}`}>
              <div class="pdp-rec-frame">
                {r.badge && <span class="pdp-rec-badge">{r.badge}</span>}
                <img src={r.gallery[0]} alt={r.name} loading="lazy" />
              </div>
              <h3 class="pdp-rec-name">{r.name}</h3>
              <p class="pdp-rec-price"><span class="pdp-rec-price-pre">from</span> <span class="pdp-rec-price-amt">{rp(r.price_min)}</span></p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .pdp { background: #fff; padding: 1.5rem 0 5rem; }
  .pdp-grid {
    max-width: 84rem; margin: 0 auto; padding: 0 1.25rem;
    display: grid; grid-template-columns: 1fr; gap: 2rem;
  }
  @media (min-width: 960px) {
    .pdp { padding: 0.75rem 0 6rem; }
    .pdp-grid { grid-template-columns: minmax(0, 1.35fr) minmax(22rem, 1fr); gap: 3.5rem; padding: 0 2.5rem; align-items: start; }
    .pdp-gallery { position: sticky; top: 100px; align-self: start; }
  }

  /* Gallery */
  .pdp-gallery { display: grid; grid-template-columns: 4.5rem 1fr; gap: 1rem; }
  @media (max-width: 540px) { .pdp-gallery { grid-template-columns: 3.5rem 1fr; gap: 0.6rem; } }
  .pdp-thumbs { display: flex; flex-direction: column; gap: 0.6rem; }
  .pdp-thumb {
    padding: 0; border: 1px solid #ececec; border-radius: 0.6rem; overflow: hidden;
    background: #f6f6f6; cursor: pointer; aspect-ratio: 4 / 5; transition: border-color 160ms ease;
  }
  .pdp-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pdp-thumb:hover { border-color: #c9c9c9; }
  .pdp-thumb.active { border-color: #1a1a1a; }
  .pdp-main {
    position: relative; border-radius: 1rem; overflow: hidden; background: #f4f4f4; aspect-ratio: 4 / 5;
  }
  .pdp-main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pdp-badge {
    position: absolute; top: 1rem; left: 1rem; z-index: 2;
    font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase; color: #1a1a1a; background: rgba(255,255,255,0.92);
    padding: 0.35rem 0.7rem; border-radius: 0.4rem; border: 1px solid #ececec;
  }

  /* Rail */
  .pdp-rail { font-family: var(--font-sans); }
  .pdp-title { font-size: clamp(1.6rem, 2.6vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; color: #1a1a1a; margin: 0 0 0.6rem; }
  .pdp-rating { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 1rem; }
  .pdp-stars { color: #ff4c00; letter-spacing: 0.1em; font-size: 0.95rem; }
  .pdp-reviews { color: #6b7280; font-size: 0.85rem; font-weight: 600; }
  .pdp-price { font-size: 1.25rem; font-weight: 700; color: #1a1a1a; margin-bottom: 1.75rem; }
  .pdp-price-note { display: block; font-size: 0.8rem; font-weight: 600; color: #9ca3af; margin-top: 0.2rem; }

  .pdp-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  @media (max-width: 380px) { .pdp-actions { grid-template-columns: 1fr; } }
  .pdp-btn {
    display: flex; align-items: center; justify-content: center; text-align: center;
    font-size: 0.9rem; font-weight: 700; letter-spacing: 0.02em; text-decoration: none;
    padding: 1rem 1rem; border-radius: 0.7rem; transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }
  .pdp-btn-wa { background: #1a1a1a; color: #fff; border: 1.5px solid #1a1a1a; }
  .pdp-btn-wa:hover { background: #000; }
  .pdp-btn-custom { background: #fff; color: #ff4c00; border: 1.5px solid #ff4c00; }
  .pdp-btn-custom:hover { background: #ff4c00; color: #fff; }
  .pdp-reassure { text-align: center; font-size: 0.78rem; font-weight: 600; color: #9ca3af; margin: 0.85rem 0 1.75rem; }

  /* Accordions */
  .pdp-acc { border-top: 1px solid #ececec; }
  .pdp-acc details { border-bottom: 1px solid #ececec; }
  .pdp-acc summary {
    list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 0; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #1a1a1a;
  }
  .pdp-acc summary::-webkit-details-marker { display: none; }
  .chev { width: 0.62rem; height: 0.62rem; border-right: 2px solid #1a1a1a; border-bottom: 2px solid #1a1a1a; transform: rotate(45deg); transition: transform 220ms ease; margin-bottom: 3px; }
  .pdp-acc details[open] .chev { transform: rotate(-135deg); margin-top: 3px; margin-bottom: 0; }
  .pdp-acc-body { padding: 0 0 1.3rem; font-size: 0.92rem; line-height: 1.6; color: #374151; }
  .pdp-acc-body p { margin: 0 0 0.7rem; }
  .pdp-acc-hint { color: #6b7280; font-size: 0.85rem; font-style: italic; }
  .pdp-spec { list-style: none; padding: 0; margin: 0 0 0.8rem; }
  .pdp-spec li { display: flex; justify-content: space-between; gap: 1rem; padding: 0.45rem 0; border-bottom: 1px dashed #f0f0f0; font-size: 0.88rem; }
  .pdp-spec-k { color: #6b7280; } .pdp-spec-v { color: #1a1a1a; font-weight: 600; text-align: right; }

  /* "How It Feels" + "Fabric / Material" cards — inside the right rail, after the accordions, no chevron */
  .pdp-card { background: #f7f7f7; border-radius: 0.85rem; padding: 1.1rem 1.15rem; margin-top: 0.9rem; }
  .pdp-card-h { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #1a1a1a; margin: 0 0 1rem; }
  .pdp-feel-label { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.7rem; }
  .pdp-feel-bar { display: block; height: 4px; background: #e6e6e6; border-radius: 999px; overflow: hidden; position: relative; }
  .pdp-feel-bar-fill { display: block; height: 100%; background: #1a1a1a; border-radius: 999px; }
  .pdp-feel-ends { display: flex; justify-content: space-between; margin-top: 0.55rem; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-weight: 400; font-size: 0.8rem; color: #6b7280; }
  .pdp-fabric-img { border-radius: 0.7rem; overflow: hidden; aspect-ratio: 16 / 9; background: #f0f0f0; margin-bottom: 1rem; }
  .pdp-fabric-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pdp-fabric-name { font-family: var(--font-sans); font-size: 1rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.3rem; }
  .pdp-fabric-desc { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-weight: 400; font-size: 0.88rem; line-height: 1.55; color: #6b7280; margin: 0; }

  /* "Lihat juga" — recommended products from the same segment, appears after the PDP */
  .pdp-rec { background: #fff; padding: 3rem 0 5rem; border-top: 1px solid #f0f0f0; }
  @media (min-width: 960px) { .pdp-rec { padding: 4rem 0 6rem; } }
  .pdp-rec-wrap { max-width: 84rem; margin: 0 auto; padding: 0 1.25rem; }
  @media (min-width: 960px) { .pdp-rec-wrap { padding: 0 2.5rem; } }
  .pdp-rec-h { font-family: var(--font-sans); font-size: clamp(1.4rem, 2.6vw, 1.9rem); font-weight: 700; letter-spacing: -0.02em; color: #1a1a1a; margin: 0 0 1.5rem; }
  .pdp-rec-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem 1rem; }
  @media (min-width: 720px) { .pdp-rec-grid { grid-template-columns: repeat(4, 1fr); gap: 2rem 1.5rem; } }
  .pdp-rec-card { display: block; text-decoration: none; color: inherit; }
  .pdp-rec-frame { position: relative; border-radius: 0.85rem; overflow: hidden; aspect-ratio: 4 / 5; background: #f5f5f5; }
  .pdp-rec-frame img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 600ms cubic-bezier(0.19,1,0.22,1); }
  .pdp-rec-badge { position: absolute; top: 0.65rem; left: 0.65rem; z-index: 2; font-family: var(--font-sans); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #1a1a1a; background: rgba(255,255,255,0.94); padding: 0.25rem 0.5rem; border-radius: 0.3rem; }
  .pdp-rec-name { font-family: var(--font-sans); font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; color: #1a1a1a; margin: 0.8rem 0 0.25rem; transition: color 180ms ease; }
  .pdp-rec-price { font-family: var(--font-sans); font-size: 0.85rem; margin: 0; }
  .pdp-rec-price-pre { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-weight: 400; color: #6b7280; }
  .pdp-rec-price-amt { font-weight: 700; color: #ff4c00; }
  @media (hover: hover) {
    .pdp-rec-card:hover .pdp-rec-frame img { transform: scale(1.05); }
    .pdp-rec-card:hover .pdp-rec-name { color: #ff4c00; }
  }
</style>

<script>
  // thumbnail → main image swap
  const main = document.getElementById('pdp-main-img') as HTMLImageElement | null;
  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.pdp-thumb'));
  if (main && thumbs.length) {
    thumbs.forEach((t) => t.addEventListener('click', () => {
      const src = t.dataset.src; if (!src) return;
      main.src = src;
      thumbs.forEach((x) => x.classList.toggle('active', x === t));
    }));
  }
</script>
