---
import BaseLayout from '../layouts/BaseLayout.astro';

const metaTitle = 'Campus — Jaket Angkatan, Merch Ospek & Wisuda | Kustom Garment';
const metaDescription = 'Dari ospek sampai wisuda — jaket angkatan, kaos panitia, jersey turnamen, sampai totebag himpunan. Custom anak kampus, tanpa minimum order.';

// --- CMS-ready content ---
const hero = {
  eyebrow: 'Campus',
  titleLead: 'Dari ospek',
  titleAccent: 'sampai wisuda.',
  sub: 'Jaket angkatan, kaos panitia, jersey turnamen, sampai totebag himpunan. Apa pun acara kampusmu, kami bikin merch-nya rapi dan kelar tepat waktu.',
  image: '/images/categories/campus.webp',
  imageAlt: 'Merch kampus custom Kustom Garment',
};

const products = [
  { image: '/images/placeholder/sample-section3a3%201.png', title: 'Jaket Angkatan', desc: 'Coach jacket & varsity dengan nama angkatan dan jurusan. Dipakai sampai lulus.' },
  { image: '/images/placeholder/sample-section3a1%201.png', title: 'Kaos Panitia', desc: 'Cotton combed buat kepanitiaan event, lengkap dengan divisi di punggung.' },
  { image: '/images/placeholder/sample-section3a4%201.png', title: 'Jersey Turnamen', desc: 'Dry-fit per fakultas atau tim, nomor punggung dan nama siap di hari-H.' },
  { image: '/images/placeholder/sample-section3a5%201.png', title: 'Totebag Himpunan', desc: 'Tote bag buat seminar, ospek, atau souvenir. Bahan tebal, sablon awet.' },
  { image: '/images/placeholder/sample-section3a2%201.png', title: 'Kemeja Wisuda', desc: 'Kemeja & polo rapi buat sidang, wisuda, sampai foto angkatan.' },
];

const reasons = [
  { no: '01', title: 'Ramah budget mahasiswa', desc: 'Order rame patungan? Harga makin masuk akal. Transparan, nggak ada biaya kaget.' },
  { no: '02', title: 'Kejar deadline acara', desc: 'Ospek minggu depan, turnamen lusa — kami biasa kerja cepat tanpa ngorbanin rapi.' },
  { no: '03', title: 'Desain dibantu dari nol', desc: 'Belum punya desain? Tim kami bantu rapikan dari coret-coretan jadi siap produksi.' },
];

const showcase = [
  { img: '/images/categories/20250412-section4-2.webp', alt: 'Jaket angkatan kampus' },
  { img: '/images/placeholder/sample-section3c.webp', alt: 'Kaos panitia event kampus' },
  { img: '/images/categories/20250412-section4-1.webp', alt: 'Merch himpunan mahasiswa' },
];

const cta = {
  lead: 'Acara kampus butuh merch?',
  label: 'Bikin merch kampus',
  wa: 'https://wa.me/6285161202499?text=' + encodeURIComponent('Halo Kustom Garment, saya mau bikin jaket angkatan / merch acara kampus.'),
};
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <main class="cat">
    <!-- HERO (orange) -->
    <section class="cat-hero is-orange">
      <div class="cat-wrap cat-hero-grid">
        <div class="cat-hero-copy">
          <span class="cat-eyebrow reveal">{hero.eyebrow}</span>
          <h1 class="cat-hero-title reveal">{hero.titleLead}<br /><span class="cat-hero-accent">{hero.titleAccent}</span></h1>
          <p class="cat-hero-sub reveal">{hero.sub}</p>
        </div>
        <div class="cat-hero-media reveal">
          <img src={hero.image} alt={hero.imageAlt} loading="eager" />
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="cat-products">
      <div class="cat-wrap">
        <h2 class="cat-h2 reveal">Yang sering dibikin anak kampus</h2>
        <div class="cat-prod-grid">
          {products.map((p, i) => (
            <article class="cat-prod reveal" style={`transition-delay:${i * 60}ms`}>
              <div class="cat-prod-frame">
                <img src={p.image} alt={p.title} loading="lazy" />
              </div>
              <h3 class="cat-prod-title">{p.title}</h3>
              <p class="cat-prod-desc">{p.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="cat-why">
      <div class="cat-wrap">
        <h2 class="cat-h2 reveal">Kenapa anak kampus pilih kami</h2>
        <div class="cat-why-grid">
          {reasons.map((r, i) => (
            <div class="cat-card reveal" style={`transition-delay:${i * 70}ms`}>
              <span class="cat-card-no">{r.no}</span>
              <h3 class="cat-card-title">{r.title}</h3>
              <p class="cat-card-desc">{r.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SHOWCASE -->
    <section class="cat-showcase">
      <div class="cat-wrap">
        <div class="cat-show-grid">
          {showcase.map((s) => (
            <div class="cat-show-frame reveal">
              <img src={s.img} alt={s.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cat-cta-sec">
      <div class="cat-wrap">
        <p class="cat-cta-lead reveal">{cta.lead}</p>
        <a class="cat-cta reveal" href={cta.wa} target="_blank" rel="noopener noreferrer">
          {cta.label} <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .cat { background: #ffffff; }
  .cat-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .cat-wrap { padding: 0 2.5rem; } }

  /* HERO (orange split) */
  .cat-hero.is-orange { background: #ff4c00; color: #ffffff; padding: 5rem 0 5.5rem; overflow: hidden; }
  @media (min-width: 1024px) { .cat-hero.is-orange { padding: 7.5rem 0 8rem; } }
  .cat-hero-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; }
  @media (min-width: 1024px) { .cat-hero-grid { grid-template-columns: 1.1fr 0.9fr; gap: 3.5rem; } }
  .cat-eyebrow {
    display: inline-block; font-family: var(--font-sans); font-weight: 700;
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); margin-bottom: 1.25rem;
  }
  .cat-hero-title {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.25rem); line-height: 1.02; letter-spacing: -0.03em;
    margin: 0 0 1.5rem; color: #ffffff;
  }
  .cat-hero-accent { color: #ff4c00; -webkit-text-stroke: 2px #ffffff; text-stroke: 2px #ffffff; }
  .cat-hero-sub {
    font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(1rem, 1.6vw, 1.25rem); line-height: 1.55;
    color: rgba(255,255,255,0.92); max-width: 34rem; margin: 0;
  }
  .cat-hero-media { border-radius: 1.5rem; overflow: hidden; aspect-ratio: 4 / 5; background: rgba(255,255,255,0.12); }
  .cat-hero-media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Shared H2 */
  .cat-h2 {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem); letter-spacing: -0.02em;
    color: #1a1a1a; margin: 0 0 2.5rem;
  }

  /* PRODUCTS */
  .cat-products { padding: 5rem 0 1rem; }
  @media (min-width: 1024px) { .cat-products { padding: 7rem 0 1.5rem; } }
  .cat-prod-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem 1.25rem; }
  @media (min-width: 768px) { .cat-prod-grid { grid-template-columns: repeat(3, 1fr); gap: 2.25rem 1.75rem; } }
  .cat-prod { display: block; }
  .cat-prod-frame {
    position: relative; border-radius: 1.25rem; overflow: hidden;
    aspect-ratio: 4 / 3; background: #f5f5f5; display: grid; place-items: center;
  }
  .cat-prod-frame img { width: 100%; height: 100%; object-fit: contain; display: block; transition: transform 700ms cubic-bezier(0.19,1,0.22,1); }
  @media (hover: hover) { .cat-prod:hover .cat-prod-frame img { transform: scale(1.06); } }
  .cat-prod-title { font-family: var(--font-sans); font-weight: 700; font-size: 1.125rem; letter-spacing: -0.01em; color: #1a1a1a; margin: 1rem 0 0.35rem; }
  .cat-prod-desc { font-family: var(--font-sans); font-weight: 600; font-size: 0.875rem; line-height: 1.5; color: #6b7280; margin: 0; }

  /* WHY */
  .cat-why { padding: 5rem 0; }
  @media (min-width: 1024px) { .cat-why { padding: 7rem 0; } }
  .cat-why-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 768px) { .cat-why-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; } }
  .cat-card { background: #f5f5f5; border-radius: 1.25rem; padding: 2rem; transition: background 280ms ease, transform 280ms ease, opacity 700ms ease; }
  .cat-card-no { font-family: var(--font-sans); font-weight: 700; font-size: 0.875rem; color: #ff4c00; letter-spacing: 0.1em; }
  .cat-card-title { font-family: var(--font-sans); font-weight: 700; font-size: 1.375rem; letter-spacing: -0.01em; color: #1a1a1a; margin: 0.75rem 0 0.5rem; }
  .cat-card-desc { font-family: var(--font-sans); font-weight: 600; font-size: 0.9375rem; line-height: 1.55; color: #6b7280; margin: 0; }
  @media (hover: hover) {
    .cat-card:hover { background: #ff4c00; transform: translateY(-4px); }
    .cat-card:hover .cat-card-no { color: #ffffff; }
    .cat-card:hover .cat-card-title { color: #ffffff; }
    .cat-card:hover .cat-card-desc { color: rgba(255,255,255,0.9); }
  }

  /* SHOWCASE */
  .cat-showcase { padding: 0 0 5rem; }
  @media (min-width: 1024px) { .cat-showcase { padding: 0 0 7rem; } }
  .cat-show-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 768px) { .cat-show-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; } }
  .cat-show-frame { border-radius: 1.25rem; overflow: hidden; aspect-ratio: 4 / 5; background: #f4f4f4; }
  .cat-show-frame img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 800ms cubic-bezier(0.19,1,0.22,1); }
  @media (hover: hover) { .cat-show-frame:hover img { transform: scale(1.05); } }

  /* CTA */
  .cat-cta-sec { padding: 0 0 6rem; }
  @media (min-width: 1024px) { .cat-cta-sec { padding: 0 0 8rem; } }
  .cat-cta-lead { font-family: var(--font-sans); font-weight: 600; font-size: 1rem; color: #6b7280; margin: 0 0 0.5rem; }
  .cat-cta {
    display: inline-flex; align-items: baseline; gap: 0.5rem; position: relative;
    font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.02em; color: #1a1a1a; text-decoration: none; padding-bottom: 0.12em;
  }
  .cat-cta span { color: #ff4c00; display: inline-block; transition: transform 320ms cubic-bezier(0.19,1,0.22,1); }
  .cat-cta::after {
    content: ''; position: absolute; left: 0; bottom: 0; width: 100%; height: 3px;
    background: #ff4c00; transform: scaleX(0); transform-origin: left;
    transition: transform 460ms cubic-bezier(0.19,1,0.22,1);
  }
  @media (hover: hover) {
    .cat-cta:hover::after { transform: scaleX(1); }
    .cat-cta:hover span { transform: translateX(8px); }
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .cat-prod-frame img, .cat-show-frame img { transition: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
