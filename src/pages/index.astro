---
/**
 * Homepage - Kustom Garment (redesign)
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Ticker from '../components/sections/Ticker.astro';
import CategoryCards from '../components/sections/CategoryCards.astro';
import CategoryShowcase from '../components/sections/CategoryShowcase.astro';
import SceneGallery from '../components/sections/SceneGallery.astro';
import SocialProof from '../components/sections/SocialProof.astro';
import EndCta from '../components/sections/EndCta.astro';
import { categories } from '../data/categories';
import siteConfig from '../data/site-config.json';

const metaTitle = 'Manufaktur Garment Custom Surabaya | Kustom Garment';
const metaDescription = 'Manufaktur garment custom di Surabaya — dari prototype sampai produksi massal. Kaos, jaket, kemeja, seragam dengan desain bebas, bahan premium, finishing rapi.';
const metaImage = '/images/og-default.png';

// LocalBusiness structured data — for local SEO / Google Maps / Knowledge Graph
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ClothingStore",
  "name": siteConfig.siteName,
  "description": siteConfig.description,
  "url": siteConfig.siteUrl,
  "logo": new URL('/images/logos/kg-logo.png', siteConfig.siteUrl).toString(),
  "image": new URL('/images/og-default.png', siteConfig.siteUrl).toString(),
  "telephone": "+62" + siteConfig.contact.whatsapp.slice(2),
  "email": siteConfig.contact.email,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteConfig.contact.address,
    "addressLocality": siteConfig.contact.city,
    "addressRegion": siteConfig.contact.province,
    "addressCountry": "ID"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -7.3083568,
    "longitude": 112.7551446
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "17:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "15:00"
    }
  ],
  "sameAs": [
    siteConfig.social.instagram,
    siteConfig.social.tiktok,
    siteConfig.social.facebook,
    siteConfig.social.youtube,
    siteConfig.social.twitter
  ]
};
---

<BaseLayout title={metaTitle} description={metaDescription} image={metaImage}>
  <!-- LocalBusiness / ClothingStore structured data -->
  <script set:html={JSON.stringify(localBusinessSchema)} type="application/ld+json" />
  <main>
    <!-- H1 for SEO (visually hidden — design uses image hero, but search engines need a text H1) -->
    <h1 class="sr-only">Manufaktur Garment Custom Surabaya — Kustom Garment</h1>

    <!-- Ticker (LED-style perks) -->
    <Ticker />

    <!-- Hero (IG-story banner slider) -->
    <Hero />

    <!-- Category cards -->
    <CategoryCards />

    <!-- Category showcases (alternating layout) -->
    <CategoryShowcase category={categories.business}  reverse={false} overlayPos="bl" />
    <CategoryShowcase category={categories.community} reverse={true}  overlayPos="br" />
    <CategoryShowcase category={categories.campus}    reverse={false} overlayPos="bl" />
    <CategoryShowcase category={categories.personal}  reverse={true}  overlayPos="br" />

    <!-- Scene gallery (use-cases) -->
    <SceneGallery />

    <!-- Social wall (@kustomgarment reels) -->
    <SocialProof />

    <!-- End CTA banner -->
    <EndCta />
  </main>
</BaseLayout>

<script>
  // Section-3 hybrid snap: firm (mandatory) through the inner panel transitions
  // (1→2, 2→3, 3→4), soft (proximity) at the first & last panels so you can scroll
  // out to the sections above/below instead of being trapped. CSS keeps proximity
  // as the desktop default; this only upgrades to mandatory while you're mid-zone.
  const html = document.documentElement;
  const mq = window.matchMedia('(min-width: 1024px)');
  const HEADER = 88; // matches scroll-padding-top

  const docTop = (el: HTMLElement) => el.getBoundingClientRect().top + window.scrollY;

  const update = () => {
    const panels = Array.from(document.querySelectorAll<HTMLElement>('.showcase'));
    if (!mq.matches || panels.length < 2) { html.style.scrollSnapType = ''; return; }
    const first = panels[0];
    const last = panels[panels.length - 1];
    const yFirst = docTop(first) - HEADER;     // scrollY when panel 1 is snapped
    const yLast = docTop(last) - HEADER;        // scrollY when panel 4 is snapped
    const y = window.scrollY;
    // Strictly between the first and last snap positions → firm. At/outside → soft.
    const inner = y > yFirst + 4 && y < yLast - 4;
    html.style.scrollSnapType = inner ? 'y mandatory' : 'y proximity';
  };

  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => { update(); ticking = false; });
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', update);
  mq.addEventListener('change', update);
  update();
</script>
