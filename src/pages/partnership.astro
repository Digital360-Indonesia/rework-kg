---
import BaseLayout from '../layouts/BaseLayout.astro';
import partnership from '../data/partnership.json';

const metaTitle = partnership.meta.title;
const metaDescription = partnership.meta.description;
const wa = 'https://wa.me/6285161202499?text=' + encodeURIComponent(partnership.waText);
const { logos, ways, collabs } = partnership;
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <main class="pt">
    <!-- HERO (orange) -->
    <section class="pt-hero">
      <div class="pt-wrap">
        <span class="pt-eyebrow reveal">Partner &amp; Sponsorship</span>
        <h1 class="pt-title reveal">Bikin sesuatu yang berdampak, bareng.</h1>
        <p class="pt-sub reveal">
          Brand, komunitas, atau event — kita bisa tumbuh bareng. Kolaborasi yang fair, produksi yang bisa diandalkan, hasil yang bikin bangga.
        </p>
      </div>
    </section>

    <!-- PARTNER LOGO MARQUEE -->
    <section class="pt-logos">
      <p class="pt-logos-label reveal">Sudah dipercaya & berkolaborasi dengan</p>
      <div class="pt-marquee">
        <div class="pt-track">
          {[...logos, ...logos].map((l) => (
            <img class="pt-logo" src={`/images/clients/${l}`} alt="Partner Kustom Garment" loading="lazy" />
          ))}
        </div>
      </div>
    </section>

    <!-- WAYS -->
    <section class="pt-ways">
      <div class="pt-wrap">
        <h2 class="pt-h2 reveal">Cara kita bisa kolaborasi</h2>
        <div class="pt-grid">
          {ways.map((w, i) => (
            <div class="pt-card reveal" style={`transition-delay:${i * 70}ms`}>
              <span class="pt-card-no">{w.no}</span>
              <h3 class="pt-card-title">{w.title}</h3>
              <p class="pt-card-desc">{w.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- RECENT COLLABS -->
    <section class="pt-collabs">
      <div class="pt-wrap">
        <h2 class="pt-h2 reveal">Kolaborasi terbaru</h2>
        <div class="pt-collab-row">
          {collabs.map((c) => (
            <div class="pt-collab">
              <div class="pt-collab-frame">
                <img src={c.img} alt={c.title} loading="lazy" />
              </div>
              <h3 class="pt-collab-title">{c.title}</h3>
              <p class="pt-collab-desc">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pt-cta-sec">
      <div class="pt-wrap">
        <p class="pt-cta-lead reveal">Punya ide kolaborasi?</p>
        <a class="pt-cta reveal" href={wa} target="_blank" rel="noopener noreferrer">
          Ajak kami kolaborasi <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .pt { background: #ffffff; }
  .pt-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .pt-wrap { padding: 0 2.5rem; } }

  /* HERO (orange) */
  .pt-hero {
    background: #ff4c00;
    color: #ffffff;
    padding: 6rem 0 6.5rem;
    text-align: center;
  }
  @media (min-width: 1024px) { .pt-hero { padding: 9rem 0 9rem; } }
  .pt-eyebrow {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1.5rem;
  }
  .pt-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0 auto 1.5rem;
    max-width: 16ch;
    color: #ffffff;
  }
  .pt-sub {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: rgba(255,255,255,0.9);
    max-width: 42rem;
    margin: 0 auto;
  }

  /* LOGO MARQUEE */
  .pt-logos { padding: 4rem 0 2rem; overflow: hidden; }
  @media (min-width: 1024px) { .pt-logos { padding: 5rem 0 2.5rem; } }
  .pt-logos-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    color: #6b7280;
    text-align: center;
    margin: 0 0 2.25rem;
  }
  .pt-marquee { overflow: hidden; }
  .pt-track {
    display: flex;
    align-items: center;
    gap: 3.5rem;
    width: max-content;
    animation: pt-scroll 40s linear infinite;
  }
  @keyframes pt-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - 1.75rem)); }
  }
  @media (prefers-reduced-motion: reduce) { .pt-track { animation: none; flex-wrap: wrap; justify-content: center; } }
  .pt-logo {
    height: 2.5rem;
    width: auto;
    object-fit: contain;
    opacity: 0.55;
    filter: grayscale(1);
    flex-shrink: 0;
  }

  /* WAYS */
  .pt-ways { padding: 4rem 0; }
  @media (min-width: 1024px) { .pt-ways { padding: 6rem 0; } }
  .pt-h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0 0 2.5rem;
  }
  .pt-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 768px) { .pt-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; } }
  .pt-card {
    background: #f5f5f5;
    border-radius: 1.25rem;
    padding: 2rem;
    transition: background 280ms ease, transform 280ms ease, opacity 700ms ease;
  }
  .pt-card-no { font-family: var(--font-sans); font-weight: 700; font-size: 0.875rem; color: #ff4c00; letter-spacing: 0.1em; }
  .pt-card-title { font-family: var(--font-sans); font-weight: 700; font-size: 1.375rem; letter-spacing: -0.01em; color: #1a1a1a; margin: 0.75rem 0 0.5rem; }
  .pt-card-desc { font-family: var(--font-sans); font-weight: 600; font-size: 0.9375rem; line-height: 1.55; color: #6b7280; margin: 0; }
  @media (hover: hover) {
    .pt-card:hover { background: #ff4c00; transform: translateY(-4px); }
    .pt-card:hover .pt-card-no { color: #ffffff; }
    .pt-card:hover .pt-card-title { color: #ffffff; }
    .pt-card:hover .pt-card-desc { color: rgba(255,255,255,0.9); }
  }

  /* COLLABS */
  .pt-collabs { padding: 2rem 0 5rem; }
  @media (min-width: 1024px) { .pt-collabs { padding: 3rem 0 7rem; } }
  /* Horizontal slider — 3 visible + peek, scrollable */
  .pt-collab-row {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    /* bleed to the right edge so the peek feels like "more" */
    margin-right: -1.5rem;
    padding-right: 1.5rem;
  }
  .pt-collab-row::-webkit-scrollbar { display: none; }
  @media (min-width: 1024px) { .pt-collab-row { margin-right: -2.5rem; padding-right: 2.5rem; } }

  .pt-collab {
    flex: 0 0 78%;
    scroll-snap-align: start;
  }
  @media (min-width: 640px) { .pt-collab { flex-basis: 44%; } }
  @media (min-width: 1024px) { .pt-collab { flex-basis: 30%; } }

  .pt-collab-frame {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #f4f4f4;
  }
  .pt-collab-frame img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 700ms cubic-bezier(0.19,1,0.22,1); }
  @media (hover: hover) { .pt-collab:hover .pt-collab-frame img { transform: scale(1.05); } }
  .pt-collab-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
    color: #1a1a1a;
    margin: 1rem 0 0.35rem;
  }
  .pt-collab-desc {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #6b7280;
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }

  /* CTA */
  .pt-cta-sec { padding: 0 0 6rem; }
  @media (min-width: 1024px) { .pt-cta-sec { padding: 0 0 8rem; } }
  .pt-cta-lead { font-family: var(--font-sans); font-weight: 600; font-size: 1rem; color: #6b7280; margin: 0 0 0.5rem; }
  .pt-cta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    position: relative;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    color: #1a1a1a;
    text-decoration: none;
    padding-bottom: 0.12em;
  }
  .pt-cta span { color: #ff4c00; display: inline-block; transition: transform 320ms cubic-bezier(0.19,1,0.22,1); }
  .pt-cta::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    width: 100%; height: 3px;
    background: #ff4c00;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 460ms cubic-bezier(0.19,1,0.22,1);
  }
  @media (hover: hover) {
    .pt-cta:hover::after { transform: scaleX(1); }
    .pt-cta:hover span { transform: translateX(8px); }
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
