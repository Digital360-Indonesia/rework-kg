---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import catalog from '../../../data/products/catalog-source.mjs';
import siteConfig from '../../../data/site-config.json';
import portfolio from '../../../data/portfolio.json';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  // one customizer per real product (portfolio item), keyed under its segment; uses its template archetype for pricing/fabrics
  const gtIds = new Set(catalog.garment_types.map((g) => g.id));
  const archBySlug = Object.fromEntries((catalog.archetypes as any[]).map((a) => [a.slug, a]));
  return (portfolio.items as any[])
    .filter((it) => gtIds.has(it.garment_type) && archBySlug[it.pdpSlug])
    .map((it) => {
      // the SAME gallery the product page shows, so the preview image matches
      let gallery: string[] = [];
      try {
        const dir = path.join(process.cwd(), 'public/images/portfolio', it.slug);
        gallery = fs.readdirSync(dir).filter((f) => /\.(webp|jpe?g|png)$/i.test(f)).map((f) => `/images/portfolio/${it.slug}/${f}`);
      } catch (e) {}
      if (it.heroImageLocal) gallery = [it.heroImageLocal, ...gallery.filter((g) => g !== it.heroImageLocal)];
      return { params: { segment: it.segment, slug: it.slug }, props: { item: it, archetype: archBySlug[it.pdpSlug], gallery } };
    });
}

const { item, archetype, gallery } = Astro.props;
// the configurator runs on the template archetype, but seeded with THIS product's real config, name, and photos
const product = { ...archetype, name: item.title, slug: item.slug, locked_spec: (item.spec && Object.keys(item.spec).length ? item.spec : archetype.locked_spec), gallery: (gallery && gallery.length ? gallery : archetype.gallery) };
const garment = catalog.garment_types.find((g) => g.id === product.garment_type)!;
const fabrics = catalog.fabrics.filter((f) => f.garment_type === product.garment_type);
const colors = catalog.colors;
const decos = catalog.decoration_types;
const rules = catalog.pricing_rules;

const defaultDecos = (product.default_decoration || []).map((d: any) => {
  const t = decos.find((dt) => dt.name.toLowerCase().startsWith(String(d.type).toLowerCase()));
  return { typeId: t ? t.id : decos[0].id, placement: d.placement };
});

const waBase = (siteConfig as any)?.contact?.whatsappUrl || 'https://wa.me/6285117049918';
const styleOptions = (garment as any).style_options || {};
const styleSelect = (garment as any).style_select || {};
// variations are LOCKED TO THE GARMENT TYPE — every product of a type offers the same axes,
// pre-selected to this product's real config, single-select axes defaulting to the first option.
const styleAttrs = Object.keys(styleOptions);
const filledSpec: Record<string, any> = { ...product.locked_spec };
styleAttrs.forEach((k) => {
  if (filledSpec[k] == null && styleSelect[k] !== 'multi' && styleOptions[k][0]) filledSpec[k] = styleOptions[k][0].name;
});
product.locked_spec = filledSpec;
const lockedSpec = Object.entries(product.locked_spec) as [string, string][];

// decoration placement map — where each placement sits on the garment diagram (% of the SVG box)
const PLACE_MAP: Record<string, { view: string; x: number; y: number; label: string }> = {
  'Collar': { view: 'front', x: 50, y: 17, label: 'Kerah' },
  'Left chest': { view: 'front', x: 37, y: 35, label: 'Dada kiri' },
  'Right chest': { view: 'front', x: 63, y: 35, label: 'Dada kanan' },
  'Name tag right chest': { view: 'front', x: 63, y: 47, label: 'Name tag' },
  'Sleeve Left': { view: 'front', x: 14, y: 45, label: 'Lengan kiri' },
  'Sleeve Right': { view: 'front', x: 86, y: 45, label: 'Lengan kanan' },
  'Back center': { view: 'back', x: 50, y: 40, label: 'Punggung' },
  'Back upper': { view: 'back', x: 50, y: 22, label: 'Punggung atas' },
  'Front center': { view: 'front', x: 50, y: 50, label: 'Tengah depan' },
};
const placeHots = garment.placements.map((p: string) => ({ name: p, ...(PLACE_MAP[p] || { view: 'front', x: 50, y: 62, label: p }) }));
const frontHots = placeHots.filter((h) => h.view === 'front');
const backHots = placeHots.filter((h) => h.view === 'back');

// size guide (placeholder cm, flat measurement) — swap for the real chart later
const SIZE_GUIDE: Record<string, [number, number]> = { S: [48, 68], M: [51, 70], L: [54, 72], XL: [57, 74], XXL: [60, 76] };
const sizeGuideRows = garment.size_run.map((s: string) => ({ size: s, chest: SIZE_GUIDE[s]?.[0] ?? '—', length: SIZE_GUIDE[s]?.[1] ?? '—' }));

const cfg = {
  slug: product.slug, name: product.name, basePrice: product.base_price_per_pc,
  defaultFabric: product.default_fabric, defaultColor: product.color_default,
  placements: garment.placements, sizeRun: garment.size_run,
  fabrics, colors, decos, rules, defaultDecos, waBase, lockedSpec,
  styleOptions, styleAttrs, defaultStyle: product.locked_spec,
};
const metaTitle = `Custom ${product.name} | Kustom Garment`;
---

<BaseLayout title={metaTitle} description={`Kustomisasi ${product.name}`} noCurtain={true} noFooter={true}>
  <style is:global>@media (min-width: 860px) { html, body { height: 100%; overflow: hidden; } }</style>
  <div class="cz">
    <div class="cz-top">
      <a class="cz-back" href={`/${item.segment}/${item.slug}`}>← {product.name}</a>
      <nav class="cz-tabs" id="cz-tabs">
        <button class="cz-tab active" data-tab="fabric">Fabric</button>
        <button class="cz-tab" data-tab="color">Color</button>
        {styleAttrs.length > 0 && <button class="cz-tab" data-tab="style">Style</button>}
        <button class="cz-tab" data-tab="decoration">Decoration</button>
        <button class="cz-tab" data-tab="size">Size</button>
        <button class="cz-tab" data-tab="summary">Summary</button>
      </nav>
    </div>

    <div class="cz-body">
      <div class="cz-preview">
        <img src={product.gallery[0]} alt={product.name} />
        <div class="cz-sel" id="cz-sel"></div>
      </div>

      <div class="cz-panels">
        <section class="cz-panel active" data-panel="fabric">
          <div class="fab-head">
            <h2 class="fab-title">Bahan</h2>
            <div class="fab-tools">
              <button class="fab-filter" aria-label="Filter">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 7h9M19 7h1M4 17h1M11 17h9"/><circle cx="16" cy="7" r="2.4"/><circle cx="8" cy="17" r="2.4"/></svg>
              </button>
              <input class="fab-search" id="cz-fabsearch" type="text" placeholder="Cari bahan…" />
            </div>
          </div>
          <p class="cz-subline">Pilih bahan dasar — harga menyesuaikan pilihan &amp; jumlah order.</p>
          <div class="fab-grid" id="cz-fabrics">
            {fabrics.map((f) => (
              <button class:list={['fab-card', { sel: f.id === product.default_fabric }]} data-fab={f.id} data-name={f.name}>
                <span class="fab-img">{f.swatch_image ? <img src={f.swatch_image} alt="" /> : <span class="cz-tex" />}</span>
                <span class="fab-check">✓</span>
                <span class="fab-cap">{f.name}</span>
                <span class="fab-info" role="button" tabindex="0" aria-label="Info bahan">i</span>
              </button>
            ))}
          </div>
          <div class="fab-detail">
            <div class="fab-detail-main">
              <div>
                <div class="fab-name" id="fd-name"></div>
                <div class="fab-sub" id="fd-sub"></div>
              </div>
              <div class="fab-detail-r">
                <div class="fab-bar-row"><span class="fab-bar"><span id="fd-bar1"></span></span><span class="fab-bar-lbl" id="fd-lbl1"></span></div>
                <div class="fab-bar-row"><span class="fab-bar"><span id="fd-bar2"></span></span><span class="fab-bar-lbl" id="fd-lbl2"></span></div>
              </div>
            </div>
          </div>
          <div class="fab-pop" id="fab-pop" hidden><span class="fab-pop-body" id="fab-pop-body"></span><span class="fab-pop-arrow"></span></div>
        </section>

        <section class="cz-panel" data-panel="color">
          <div class="col-head">
            <h2 class="col-title">Warna</h2>
            <label class="col-customwrap">
              <span class="col-customlbl">Custom?</span>
              <input class="col-customin" id="cz-customcolor" type="text" placeholder="Tulis warna / kode" />
            </label>
          </div>
          <p class="cz-subline">Warna dasar kain. Butuh warna spesifik? Isi kolom custom.</p>
          <div class="col-grid" id="cz-colors">
            {colors.map((c) => (
              <button class:list={['col-card', { sel: c.id === product.color_default }]} data-color={c.id} data-name={c.name} data-hex={c.hex}>
                <span class="col-sw" style={`--c:${c.hex}`}><span class="col-check">✓</span></span>
                <span class="col-cardname">{c.name}</span>
              </button>
            ))}
          </div>
          <div class="col-detail">
            <div class="col-detail-main">
              <span class="col-detail-sw" id="cd-sw"></span>
              <div>
                <div class="col-name" id="cd-name"></div>
                <div class="col-sub" id="cd-sub"></div>
              </div>
            </div>
          </div>
        </section>

        {styleAttrs.length > 0 && (
        <section class="cz-panel" data-panel="style">
          <div class="st-stage">
              <!-- pane 0: LIST -->
              <div class="st-pane">
                <div class="st-list" id="st-list">
                  <div class="st-lhead">
                    <h2 class="st-title">Style</h2>
                    <p class="st-lsub">{styleAttrs.length > 0 ? 'Pakai default kurasi kami, atau ubah tiap detail.' : 'Spec dasar terkunci — semua detail sudah disesuaikan untuk produk ini.'}</p>
                  </div>
                  <div class="st-rows">
                    {styleAttrs.length > 0 ? styleAttrs.map((k) => (
                      <button class="st-row" data-attr={k}>
                        <span class="st-row-k">{k}</span>
                        <span class="st-row-r"><span class="st-row-v" data-valfor={k}>{Array.isArray((product.locked_spec as any)[k]) ? ((product.locked_spec as any)[k] as string[]).join(', ') : (product.locked_spec as any)[k]}</span><span class="st-chev"></span></span>
                      </button>
                    )) : lockedSpec.map(([k, v]) => (
                      <div class="st-row st-row-locked"><span class="st-row-k">{k}</span><span class="st-row-r"><span class="st-row-v">{v}</span></span></div>
                    ))}
                  </div>
                </div>
              </div>
              <!-- panes 1..n: DETAIL per attribute -->
              {styleAttrs.map((k) => (
                <div class="st-pane" hidden>
                  <div class="st-detail-view" data-attrview={k}>
                    <aside class="st-rail">
                      {styleAttrs.map((k2) => (
                        <button class:list={['st-railitem', { on: k2 === k }]} data-railattr={k2}>{k2}</button>
                      ))}
                    </aside>
                    <div class="st-main">
                      <div class="st-dhead">
                        <button class="st-back" data-back aria-label="Kembali">‹</button>
                        <h2 class="st-dtitle">{k}</h2>
                      </div>
                      <div class="st-optgrid">
                        {(styleOptions[k] || []).map((o: any) => (
                          <button class:list={['st-opt', { sel: Array.isArray((product.locked_spec as any)[k]) ? ((product.locked_spec as any)[k] as string[]).includes(o.name) : o.name === (product.locked_spec as any)[k] }]} data-attr={k} data-opt={o.name}>
                            <span class="st-opt-ill">{o.illustration ? <img src={o.illustration} alt="" /> : <span class="st-opt-ph">{o.name}</span>}<span class="st-opt-check">✓</span></span>
                            <span class="st-opt-name">{o.name}</span>
                          </button>
                        ))}
                      </div>
                      <div class="st-detail">
                        <div class="st-detail-l">
                          <div class="st-dname"></div>
                          <div class="st-ddesc"></div>
                        </div>
                        <div class="st-dsug"></div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
          </div>
        </section>
        )}

        <section class="cz-panel" data-panel="decoration">
          <div class="deco-head"><h2 class="deco-title">Dekorasi</h2></div>
          <p class="cz-subline">Klik titik di baju, lalu pilih teknik untuk titik itu.</p>
          <div class="dm-scroll">
            <div class="dm-views">
              <button class="dm-viewtab on" data-view="front">Depan</button>
              <button class="dm-viewtab" data-view="back">Belakang</button>
            </div>
            <div class="dm-stage">
              <div class="dm-shirt" data-shirtview="front">
                <svg viewBox="0 0 200 230" fill="none" stroke="#cfcfcf" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
                  <path d="M74 26 L58 18 L18 46 L34 72 L50 64 L50 208 Q100 218 150 208 L150 64 L166 72 L182 46 L142 18 L126 26 Q100 48 74 26 Z"/>
                  <path d="M74 26 Q100 50 126 26"/>
                  <path d="M82 22 Q100 40 118 22"/>
                  <path d="M100 48 L100 200" stroke-dasharray="3 6"/>
                </svg>
                {frontHots.map((h) => (
                  <button class="dm-hot" data-place={h.name} data-label={h.label} style={`left:${h.x}%;top:${h.y}%`}>
                    <span class="dm-dot"></span><span class="dm-htlabel">{h.label}</span>
                  </button>
                ))}
              </div>
              <div class="dm-shirt" data-shirtview="back" hidden>
                <svg viewBox="0 0 200 230" fill="none" stroke="#cfcfcf" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true">
                  <path d="M74 26 L58 18 L18 46 L34 72 L50 64 L50 208 Q100 218 150 208 L150 64 L166 72 L182 46 L142 18 L126 26 Q100 36 74 26 Z"/>
                  <path d="M76 24 Q100 34 124 24"/>
                  <path d="M54 60 Q100 72 146 60"/>
                </svg>
                {backHots.map((h) => (
                  <button class="dm-hot" data-place={h.name} data-label={h.label} style={`left:${h.x}%;top:${h.y}%`}>
                    <span class="dm-dot"></span><span class="dm-htlabel">{h.label}</span>
                  </button>
                ))}
              </div>
            </div>
            <p class="dm-hint">Titik oranye sudah ada dekorasi — klik untuk ubah.</p>
            <div class="dm-chooser" id="dm-chooser" hidden></div>
          </div>
          <div class="deco-detail">
            <div class="deco-detail-l"><span id="deco-count">0 dekorasi</span></div>
            <div class="deco-detail-r"><span class="deco-detail-lbl">Tambahan</span><span id="deco-total">+Rp 0</span><span class="deco-detail-note">/pc</span></div>
          </div>
        </section>

        <section class="cz-panel" data-panel="size">
          <div class="sz-head">
            <h2 class="sz-title">Ukuran</h2>
            <button class="sz-guide-btn" id="sz-guidebtn">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l4-4 14 14-4 4z"/><path d="M8 8l1.5 1.5M11 11l1.5 1.5M14 14l1.5 1.5"/></svg>
              Panduan ukuran
            </button>
          </div>
          <p class="cz-subline">Isi jumlah per ukuran. Minimum order 24 pcs.</p>
          <div class="sz-scroll">
            <div class="sz-group">
              <div class="sz-grouplabel">Fit</div>
              <div class="sz-seg" id="sz-fit">
                <button class="sz-segopt locked" data-fit="slim" disabled>Slim</button>
                <button class="sz-segopt on" data-fit="regular">Regular</button>
                <button class="sz-segopt locked" data-fit="relaxed" disabled>Relaxed</button>
              </div>
              <p class="sz-soon">Slim &amp; Relaxed segera hadir.</p>
            </div>
            <div class="sz-group">
              <div class="sz-grouplabel" id="sz-lenlabel">Length</div>
              <div class="sz-seg" id="sz-length">
                <button class="sz-segopt locked" data-length="short" disabled>Short</button>
                <button class="sz-segopt on" data-length="regular">Regular</button>
                <button class="sz-segopt locked" data-length="tall" disabled>Tall</button>
              </div>
              <p class="sz-soon">Short &amp; Tall segera hadir.</p>
            </div>
            <div class="sz-group">
              <div class="sz-grouplabel">Jumlah per ukuran</div>
              <div class="cz-sizes" id="cz-sizes"></div>
            </div>
          </div>
          <div class="sz-detail">
            <div class="sz-detail-l">Total <strong id="cz-qty">0</strong> pcs</div>
            <div class="sz-detail-r" id="sz-fitsum">Regular · Regular</div>
          </div>
        </section>

        <section class="cz-panel" data-panel="summary">
          <div class="sm-head"><h2 class="sm-title">Ringkasan</h2></div>
          <p class="cz-subline">Cek detail pesanan, lalu lanjut ke WhatsApp untuk konfirmasi &amp; harga final.</p>
          <div class="sm-scroll">
            <div class="sm-price" id="cz-pricecard"></div>
            <div id="cz-summary"></div>
          </div>
          <div class="sm-cta">
            <a class="sm-wa" id="cz-wa" href="#" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2zm0 18.2c-1.5 0-2.9-.4-4.2-1.1l-.3-.18-2.85.9.93-2.78-.2-.32A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.25-.13-1.47-.73-1.7-.8-.23-.1-.4-.13-.56.12-.16.25-.64.8-.78.97-.14.16-.29.18-.53.06-.25-.13-1.05-.39-2-1.23-.74-.66-1.24-1.47-1.38-1.72-.14-.25-.02-.38.1-.5.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.16.04-.31-.02-.43-.06-.13-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42l-.48-.01c-.16 0-.43.06-.65.31-.22.25-.86.84-.86 2.05 0 1.2.88 2.37 1 2.53.13.17 1.74 2.65 4.2 3.72.59.25 1.05.4 1.4.52.6.18 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.2-.58.2-1.07.14-1.18-.06-.1-.22-.16-.47-.29z"/></svg>
              Lanjut via WhatsApp
            </a>
            <p class="sm-disclaimer">Estimasi harga. Final price &amp; ketersediaan dikonfirmasi via WhatsApp.</p>
          </div>
        </section>
      </div>
    </div>

    <div class="cz-bar">
      <button class="cz-nav" id="cz-prev">Kembali</button>
      <div class="cz-price"><span id="cz-perpc">—</span> <span class="cz-perpc-note">/pc (est.)</span></div>
      <button class="cz-nav cz-next" id="cz-next">Lanjut →</button>
    </div>

    <div class="sz-modal" id="sz-modal" hidden>
      <div class="sz-modal-backdrop" id="sz-modalbd"></div>
      <div class="sz-modal-card">
        <div class="sz-modal-head">
          <h3>Panduan Ukuran — {garment.name}</h3>
          <button class="sz-modal-close" id="sz-modalclose" aria-label="Tutup">✕</button>
        </div>
        <table class="sz-table">
          <thead><tr><th>Ukuran</th><th>Lebar dada</th><th>Panjang badan</th></tr></thead>
          <tbody>
            {sizeGuideRows.map((r) => (
              <tr><td>{r.size}</td><td>{r.chest} cm</td><td>{r.length} cm</td></tr>
            ))}
          </tbody>
        </table>
        <p class="sz-modal-note">Flat measurement, toleransi ±1–2 cm. Butuh ukuran khusus atau size chart per orang? Konfirmasi via WhatsApp.</p>
      </div>
    </div>
  </div>

  <script type="application/json" id="cz-cfg" set:html={JSON.stringify(cfg)}></script>
</BaseLayout>

<style is:global>
  /* global (not scoped): much of this panel is rendered by JS (innerHTML), and Astro scoped
     styles don't reach JS-injected nodes. Selectors are all .cz-/.fab-/.col-/.st-/.deco- specific,
     and this CSS only ships on the customizer route, so global is safe here. */
  .cz { font-family: var(--font-sans); display: flex; flex-direction: column; min-height: calc(100vh - 88px); background: #fff; }
  /* Desktop: lock the customizer to one screen — no page scroll, panels scroll internally */
  @media (min-width: 860px) { .cz { height: calc(100vh - 88px); min-height: 0; overflow: hidden; } }
  .cz-top { border-bottom: 1px solid #ececec; padding: 0.5rem 1.25rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .cz-back { color: #6b7280; text-decoration: none; font-size: 0.85rem; font-weight: 600; white-space: nowrap; }
  .cz-back:hover { color: #ff4c00; }
  .cz-tabs { display: flex; gap: 1.4rem; overflow-x: auto; scrollbar-width: none; }
  .cz-tabs::-webkit-scrollbar { display: none; }
  .cz-tab { background: none; border: 0; padding: 0.9rem 0; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #9ca3af; cursor: pointer; border-bottom: 2px solid transparent; white-space: nowrap; transition: color 160ms ease; }
  .cz-tab.active { color: #1a1a1a; border-bottom-color: #ff4c00; }

  .cz-body { flex: 1; display: grid; grid-template-columns: 1fr; }
  @media (min-width: 860px) { .cz-body { grid-template-columns: 1fr 1fr; min-height: 0; overflow: hidden; } }

  .cz-preview { background: #f4f4f4; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem 1.5rem; gap: 1rem; }
  @media (min-width: 860px) { .cz-preview { height: 100%; min-height: 0; overflow: hidden; } }
  .cz-preview img { max-width: 100%; max-height: 60vh; object-fit: contain; border-radius: 0.75rem; }
  .cz-sel { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; }
  .cz-sel .chip { font-size: 0.75rem; font-weight: 600; color: #374151; background: #fff; border: 1px solid #ececec; border-radius: 999px; padding: 0.25rem 0.6rem; }

  .cz-panels { display: flex; flex-direction: column; min-height: 0; }
  @media (min-width: 860px) { .cz-panels { height: 100%; overflow: hidden; } }
  .cz-panel { display: none; }
  .cz-panel.active { display: block; animation: czfade 0.35s cubic-bezier(0.19,1,0.22,1); }
  @media (min-width: 860px) {
    .cz-panel.active { flex: 1; min-height: 0; }
  }
  @keyframes czfade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  .cz-h { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.01em; color: #1a1a1a; margin: 0 0 1.25rem; }
  .cz-h-note { font-size: 0.9rem; font-weight: 600; color: #9ca3af; letter-spacing: 0; }
  .cz-hint { font-size: 0.85rem; color: #6b7280; margin: 1rem 0 0; }
