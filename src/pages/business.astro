---
import BaseLayout from '../layouts/BaseLayout.astro';
import EndCta from '../components/sections/EndCta.astro';
import ProductLineup from '../components/sections/ProductLineup.astro';

const metaTitle = 'Business — Seragam & Apparel Kerja | Kustom Garment';
const metaDescription = 'Seragam kantor, polo, kemeja, sampai wearpack — dibikin rapi dan on-brand untuk timmu. Tanpa minimum order, bordir logo beres, invoice & faktur pajak siap.';

// --- CMS-ready content ---
const hero = {
  banner: '/images/placeholder/sample-herobusiness.png',
  bannerAlt: 'Seragam & apparel kerja custom Kustom Garment',
  title: 'Seragam & apparel kerja',
  sub: 'Dari polo kantor sampai wearpack lapangan — bikin tim kamu tampil seragam, on-brand, dan nyaman dipakai kerja seharian. Tanpa minimum order, bordir logo rapi, invoice & faktur pajak siap.',
};

// Customer/client logos for the trust strip.
const clients = ['klien-1.png','klien-2.png','klien-3.png','klien-4.png','klien-5.png','klien-6.png','klien-7.png','klien-8.png','klien-9.png','klien-10.png','klien-11.png','klien-12.png','klien-13.png'];

// Product-type filters. Thumbnails = the transparent lineup cutouts. 'all' renders a grid icon.
const LU = (name: string) => `/images/placeholder/forproducts/20250428-Business_Line-Up_${name}-r544xqu3jmqddg603jussaip9yxnizaejhckc01cdk.webp`;
const lineupFilters = [
  { id: 'all',      label: 'Semua',    image: '' },
  { id: 'kemeja',   label: 'Kemeja',   image: LU('Kemeja') },
  { id: 'polo',     label: 'Polo',     image: LU('Polo') },
  { id: 'kaos',     label: 'Kaos',     image: LU('Kaos') },
  { id: 'jaket',    label: 'Jaket',    image: LU('Jaket') },
  { id: 'wearpack', label: 'Wearpack', image: LU('Wearpack') },
  { id: 'rompi',    label: 'Rompi',    image: LU('Rompi') },
];

// Color palette (name → hex). SAMPLE — swap for real warna/bahan later.
const C: Record<string, string> = {
  'Putih': '#f4f4f4', 'Hitam': '#1a1a1a', 'Navy': '#1b2a4a', 'Abu': '#9ca3af',
  'Abu Misty': '#b8bcc2', 'Krem': '#e8dcc6', 'Biru Muda': '#bcd3e8', 'Maroon': '#6d1f2f',
  'Olive': '#5b6236', 'Khaki': '#b3a06a', 'Pink Muda': '#e8c4cc', 'Oranye': '#ee6a2a',
  'Sage': '#b3c2a3', 'Coklat': '#6b4a2f',
};
const mk = (names: string[]) => names.map((n) => ({ name: n, hex: C[n] }));

// Product grid (SAMPLE). base = flat shot, weared = worn shot (hover swap).
// Each card: own colors (first = default shown), '+more' count, and price — all sample data.
const fp = '/images/placeholder/forproducts';
const shopProducts = [
  { name: 'Kemeja Formal Non-Iron',    category: 'kemeja',   base: `${fp}/p1.jpg`, weared: `${fp}/weared1.jpg`, colors: mk(['Putih','Biru Muda','Navy','Abu','Hitam']),    more: 8,  price: 'Rp 159.000' },
  { name: 'Jaket Harrington',          category: 'jaket',    base: `${fp}/p2.jpg`, weared: `${fp}/weared2.jpg`, colors: mk(['Olive','Navy','Hitam','Khaki','Maroon']),     more: 4,  price: 'Rp 285.000' },
  { name: 'Polo Pique Premium',        category: 'polo',     base: `${fp}/p3.jpg`, weared: `${fp}/weared3.jpg`, colors: mk(['Navy','Putih','Hitam','Abu','Maroon']),       more: 6,  price: 'Rp 129.000' },
  { name: 'Kaos Cotton Combed 24s',    category: 'kaos',     base: `${fp}/p4.jpg`, weared: `${fp}/weared4.jpg`, colors: mk(['Hitam','Putih','Abu Misty','Navy','Maroon']), more: 12, price: 'Rp 89.000' },
  { name: 'Kemeja Oxford Button-Down', category: 'kemeja',   base: `${fp}/p5.jpg`, weared: `${fp}/weared5.jpg`, colors: mk(['Biru Muda','Putih','Pink Muda','Abu','Navy']),more: 5,  price: 'Rp 169.000' },
  { name: 'Wearpack Drill Pro',        category: 'wearpack', base: `${fp}/p6.jpg`, weared: `${fp}/weared6.jpg`, colors: mk(['Navy','Abu','Hitam','Oranye','Khaki']),       more: 3,  price: 'Rp 245.000' },
  { name: 'Rompi Outdoor Lapangan',    category: 'rompi',    base: `${fp}/p7.jpg`, weared: `${fp}/weared7.jpg`, colors: mk(['Hitam','Olive','Navy','Abu','Oranye']),       more: 4,  price: 'Rp 119.000' },
  { name: 'Kemeja Linen Krem',         category: 'kemeja',   base: `${fp}/p8.jpg`, weared: `${fp}/weared8.jpg`, colors: mk(['Krem','Putih','Biru Muda','Sage','Coklat']),  more: 6,  price: 'Rp 175.000' },
];

// Comparison — Kustom Garment vs the alternatives. KG is always ✓; the alternative is
// 'no' (✗), 'partial' (– = terbatas/tergantung), or 'yes' (✓) per row.
const ICON_YES = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12.5l5 5L20 6.5"/></svg>';
const ICON_NO = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>';
const ICON_PARTIAL = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M6 12h12"/></svg>';
const markIco = (v: string) => (v === 'yes' ? ICON_YES : v === 'partial' ? ICON_PARTIAL : ICON_NO);
const markCls = (v: string) => (v === 'yes' ? 'cat-cmp-yes' : v === 'partial' ? 'cat-cmp-partial' : 'cat-cmp-no');
const compare = {
  title: 'Kustom Garment vs. cara lain',
  sub: 'Sebelum mulai, bandingkan dulu. Pilih cara lain yang biasa kamu pertimbangkan, lalu lihat kenapa custom bareng Kustom Garment paling masuk akal buat tim kamu.',
  groups: [
    { id: 'konveksi', label: 'Konveksi', rows: [
      { feature: 'Bisa pesan satuan, tanpa minimum order', alt: 'no' },
      { feature: 'Gratis desain & konsultasi',             alt: 'partial' },
      { feature: 'Update progres tiap tahap',              alt: 'no' },
      { feature: 'Garansi jahitan & revisi',               alt: 'partial' },
      { feature: 'Harga transparan di awal',               alt: 'partial' },
    ] },
    { id: 'ready', label: 'Ready stock', rows: [
      { feature: 'Desain, warna & potongan bebas',  alt: 'no' },
      { feature: 'Logo, nama & nomor sesuai tim',   alt: 'no' },
      { feature: 'Pilih bahan sesuai kebutuhan',    alt: 'no' },
      { feature: 'Identitas brand yang konsisten',  alt: 'no' },
      { feature: 'Eksklusif, nggak pasaran',        alt: 'no' },
      { feature: 'Stok ukuran lengkap buat tim',    alt: 'partial' },
    ] },
    { id: 'impor', label: 'Vendor impor', rows: [
      { feature: 'Produksi lokal, komunikasi langsung', alt: 'no' },
      { feature: 'Revisi & sample cepat',               alt: 'partial' },
      { feature: 'Tanpa bea cukai & ongkir mahal',      alt: 'no' },
      { feature: 'Bisa mulai dari jumlah kecil',        alt: 'no' },
    ] },
  ],
};
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <main class="cat">
    <!-- HERO (banner) -->
    <section class="cat-hero2">
      <div class="cat-banner-wrap reveal">
        <div class="cat-banner">
          <img src={hero.banner} alt={hero.bannerAlt} loading="eager" />
        </div>
      </div>
      <div class="cat-hero2-inner">
        <h1 class="cat-hero2-title reveal">{hero.title}</h1>
        <p class="cat-hero2-sub reveal">{hero.sub}</p>
      </div>
    </section>

    <!-- CUSTOMER STRIP -->
    <section class="cat-clients">
      <div class="cat-clients-marquee">
        <div class="cat-clients-track">
          {[...clients, ...clients].map((l) => (
            <div class="cat-client-card"><img src={`/images/clients/${l}`} alt="Klien Kustom Garment" loading="lazy" /></div>
          ))}
        </div>
      </div>
    </section>

    <!-- CUSTOMIZE-ONLINE LINEUP (catalog-driven → product page → customizer) -->
    <ProductLineup segment="business" title="Bisa kamu kustom online" subtitle="Pilih produk, atur sendiri bahan, warna, style & dekorasi, lalu lanjut via WhatsApp." />

    <!-- PRODUCT FILTER (lineup) -->
    <section class="cat-lineup">
      <div class="cat-wrap">
        <div class="cat-lineup-row reveal">
          {lineupFilters.map((f, i) => (
            <button class:list={["cat-lineup-item", { 'is-active': i === 0 }]} data-filter={f.id} type="button">
              <span class="cat-lineup-thumb">
                {f.image
                  ? <img src={f.image} alt={f.label} loading="lazy" />
                  : <span class="cat-lineup-all" aria-hidden="true"><i></i><i></i><i></i><i></i></span>}
              </span>
              <span class="cat-lineup-label">{f.label}</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- PRODUCT GRID -->
    <section class="cat-shop">
      <div class="cat-wrap">
        <div class="cat-shop-grid">
          {shopProducts.map((p, i) => (
            <article class="cat-shop-card reveal" style={`transition-delay:${(i % 4) * 60}ms`} data-category={p.category}>
              <div class="cat-shop-frame">
                <img class="cat-shop-base" src={p.base} alt={p.name} loading="lazy" />
                <img class="cat-shop-weared" src={p.weared} alt={`${p.name} dipakai`} loading="lazy" />
              </div>
              <h3 class="cat-shop-name">{p.name}</h3>
              <p class="cat-shop-color">{p.colors[0].name}</p>
              <div class="cat-shop-swatches">
                {p.colors.map((c, ci) => (
                  <button class:list={["cat-shop-swatch", { 'is-active': ci === 0 }]} style={`--sw:${c.hex}`} data-color={c.name} title={c.name} aria-label={c.name} type="button"></button>
                ))}
                {p.more > 0 && <span class="cat-shop-more">+{p.more}</span>}
              </div>
              <p class="cat-shop-price"><span class="cat-shop-price-pre">from</span> <span class="cat-shop-price-amt">{p.price}</span></p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON -->
    <section class="cat-cmp">
      <div class="cat-wrap">
        <div class="cat-cmp-box">
          <h2 class="cat-cmp-title reveal">{compare.title}</h2>
          <p class="cat-cmp-sub reveal">{compare.sub}</p>
          <div class="cat-cmp-tabs reveal" role="tablist" aria-label="Bandingkan dengan">
            {compare.groups.map((g, i) => (
              <button class:list={["cat-cmp-tab", { 'is-active': i === 0 }]} data-cmp={g.id} type="button" role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{g.label}</button>
            ))}
          </div>

          {compare.groups.map((g, i) => (
            <div class:list={["cat-cmp-panel", { 'is-active': i === 0 }]} data-cmp-panel={g.id} hidden={i !== 0}>
              <div class="cat-cmp-card reveal">
                <div class="cat-cmp-scroll">
                  <table class="cat-cmp-table">
                    <thead>
                      <tr>
                        <th class="cat-cmp-feat" scope="col"><span class="cat-cmp-sr">Keunggulan</span></th>
                        <th class="cat-cmp-col cat-cmp-col-kg" scope="col">
                          <img class="cat-cmp-logo" src="/images/logos/kg-logo.png" alt="Kustom Garment" loading="lazy" />
                        </th>
                        <th class="cat-cmp-col" scope="col">{g.label}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {g.rows.map((f) => (
                        <tr>
                          <th class="cat-cmp-feat" scope="row">{f.feature}</th>
                          <td class="cat-cmp-cell cat-cmp-col-kg"><span class="cat-cmp-mark cat-cmp-yes" set:html={ICON_YES}></span></td>
                          <td class="cat-cmp-cell"><span class:list={["cat-cmp-mark", markCls(f.alt)]} set:html={markIco(f.alt)}></span></td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BANNER (reused homepage end-CTA: "Idemu, tinggal satu chat lagi.") closes the page -->
    <EndCta />
  </main>
</BaseLayout>

<style>
  .cat { background: #ffffff; }
  .cat-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .cat-wrap { padding: 0 2.5rem; } }

  /* HERO (banner) */
  .cat-hero2 { padding: 1.5rem 0 0; }
  @media (min-width: 1024px) { .cat-hero2 { padding: 2rem 0 0; } }
  .cat-banner-wrap { max-width: 90rem; margin: 0 auto; padding: 0 1rem; }
  @media (min-width: 1024px) { .cat-banner-wrap { padding: 0 1.5rem; } }
  .cat-banner { border-radius: 1.75rem; overflow: hidden; aspect-ratio: 16 / 9; background: #f4f4f4; }
  @media (min-width: 640px) { .cat-banner { aspect-ratio: 16 / 6; } }
  @media (min-width: 1024px) { .cat-banner { aspect-ratio: 24 / 6; } }
  .cat-banner img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .cat-hero2-inner { max-width: 60rem; margin: 0 auto; padding: 2.5rem 1.5rem 0; text-align: center; }
  @media (min-width: 1024px) { .cat-hero2-inner { padding: 3rem 2.5rem 0; } }
  /* Type scale — Display */
  .cat-hero2-title { font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.875rem, 4vw, 3.25rem); line-height: 1.05; letter-spacing: -0.03em; color: #1a1a1a; margin: 0 0 1rem; }
  /* Type scale — Lead */
  .cat-hero2-sub { font-family: var(--font-sans); font-weight: 600; font-size: clamp(1rem, 1.3vw, 1.0625rem); line-height: 1.6; color: #6b7280; max-width: 40rem; margin: 0 auto; }

  /* CUSTOMER STRIP */
  .cat-clients { padding: 1.75rem 0 1rem; overflow: hidden; }
  @media (min-width: 1024px) { .cat-clients { padding: 2.25rem 0 1.5rem; } }
  .cat-clients-marquee { overflow: hidden; -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent); }
  .cat-clients-track { display: flex; gap: 1rem; width: max-content; animation: cat-clients-scroll 38s linear infinite; }
  @keyframes cat-clients-scroll { from { transform: translateX(0); } to { transform: translateX(calc(-50% - 0.5rem)); } }
  @media (prefers-reduced-motion: reduce) { .cat-clients-track { animation: none; flex-wrap: wrap; justify-content: center; } .cat-clients-marquee { -webkit-mask-image: none; mask-image: none; } }
  .cat-client-card {
    flex-shrink: 0; height: 5rem; width: 9.5rem; display: grid; place-items: center;
    background: #ffffff; border: 1px solid #ececec; border-radius: 1rem; padding: 1rem;
  }
  .cat-client-card img { max-height: 2.5rem; max-width: 100%; width: auto; object-fit: contain; filter: grayscale(1); opacity: 0.6; }


  /* PRODUCT FILTER (lineup) */
  .cat-lineup { padding: 4.5rem 0 0.5rem; }
  @media (min-width: 1024px) { .cat-lineup { padding: 6rem 0 0.5rem; } }
  .cat-lineup-row {
    display: flex; gap: 1.25rem; overflow-x: auto; scroll-snap-type: x proximity;
    scrollbar-width: none; padding-top: 0.5rem; padding-bottom: 0.5rem;
    margin: 0 -1.5rem; padding-left: 1.5rem; padding-right: 1.5rem;
  }
  .cat-lineup-row::-webkit-scrollbar { display: none; }
  @media (min-width: 1024px) { .cat-lineup-row { margin: 0 -2.5rem; padding-left: 2.5rem; padding-right: 2.5rem; justify-content: flex-start; } }
  .cat-lineup-item {
    flex: 0 0 auto; width: 6rem; background: none; border: none; padding: 0; cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 0.55rem; scroll-snap-align: start;
  }
  .cat-lineup-thumb { width: 100%; aspect-ratio: 1 / 1; border-radius: 50%; overflow: hidden; background: #f4f4f4; display: grid; place-items: center; padding: 16%; box-shadow: 0 0 0 2px transparent, 0 0 0 4px transparent; transition: box-shadow 200ms ease; }
  .cat-lineup-thumb img { width: 100%; height: 100%; object-fit: contain; display: block; transition: transform 600ms cubic-bezier(0.19,1,0.22,1); }
  .cat-lineup-all { display: grid; grid-template-columns: 1fr 1fr; gap: 22%; width: 64%; height: 64%; }
  .cat-lineup-all i { background: #c4c4c4; border-radius: 0.2rem; transition: background 200ms ease; }
  .cat-lineup-label { font-family: var(--font-sans); font-weight: 700; font-size: 0.8125rem; color: #6b7280; transition: color 200ms ease; }
  .cat-lineup-item.is-active .cat-lineup-thumb { box-shadow: 0 0 0 2px #fff, 0 0 0 4px #ff4c00; }
  .cat-lineup-item.is-active .cat-lineup-all i { background: #ff4c00; }
  .cat-lineup-item.is-active .cat-lineup-label { color: #1a1a1a; }
  @media (hover: hover) {
    .cat-lineup-item:hover .cat-lineup-thumb img { transform: scale(1.06); }
    .cat-lineup-item:hover .cat-lineup-label { color: #ff4c00; }
  }

  /* PRODUCT GRID */
  /* Widen the product module (filter + grid) beyond the page's 72rem so cards get bigger */
  @media (min-width: 1024px) { .cat-lineup .cat-wrap, .cat-shop .cat-wrap { max-width: 90rem; } }
  .cat-shop { padding: 2.5rem 0 5rem; }
  @media (min-width: 1024px) { .cat-shop { padding: 3rem 0 7rem; } }
  .cat-shop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem 1.25rem; }
  @media (min-width: 768px) { .cat-shop-grid { grid-template-columns: repeat(3, 1fr); gap: 2.75rem 1.5rem; } }
  @media (min-width: 1024px) { .cat-shop-grid { grid-template-columns: repeat(5, 1fr); } }
  .cat-shop-card { display: block; }
  .cat-shop-card.is-hidden { display: none; }
  .cat-shop-card.cat-shop-anim { animation: cat-shop-pop 460ms cubic-bezier(0.19,1,0.22,1) both; }
  @keyframes cat-shop-pop { from { opacity: 0; transform: translateY(12px) scale(0.985); } to { opacity: 1; transform: none; } }
  .cat-shop-frame { position: relative; border-radius: 1rem; overflow: hidden; aspect-ratio: 3 / 4; background: #f4f4f4; }
  .cat-shop-base, .cat-shop-weared { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 450ms ease; }
  .cat-shop-weared { opacity: 0; }
  @media (hover: hover) {
    .cat-shop-card:hover .cat-shop-base { opacity: 0; }
    .cat-shop-card:hover .cat-shop-weared { opacity: 1; }
  }
  .cat-shop-name { font-family: var(--font-sans); font-weight: 400; font-size: 1.0625rem; line-height: 1.2; letter-spacing: -0.01em; color: #1a1a1a; margin: 0.9rem 0 0; }
  .cat-shop-color { font-family: var(--font-sans); font-weight: 400; font-size: 0.875rem; color: #9ca3af; margin: 0.2rem 0 0; }
  .cat-shop-swatches { display: flex; align-items: center; gap: 0.4rem; margin-top: 0.7rem; }
  .cat-shop-swatch {
    width: 1.5rem; height: 1.2rem; border-radius: 0.3rem; background: var(--sw);
    border: 1px solid rgba(0,0,0,0.12); padding: 0; cursor: pointer;
    box-shadow: 0 0 0 2px #fff, 0 0 0 2px transparent; transition: box-shadow 180ms ease;
  }
  .cat-shop-swatch.is-active { box-shadow: 0 0 0 2px #fff, 0 0 0 3px #9ca3af; }
  .cat-shop-more { font-family: var(--font-sans); font-weight: 600; font-size: 0.8125rem; color: #6b7280; margin-left: 0.2rem; }
  .cat-shop-price { font-family: var(--font-sans); font-size: 0.8125rem; margin: 0.75rem 0 0; }
  .cat-shop-price-pre { font-weight: 400; font-size: 0.8125rem; color: #6b7280; }
  .cat-shop-price-amt { font-weight: 600; color: #ff4c00; }

  /* COMPARISON */
  .cat-cmp { padding: 2.5rem 0 1rem; }
  @media (min-width: 1024px) { .cat-cmp { padding: 3.5rem 0 1.5rem; } }
  .cat-cmp-box { background: #fff7f2; border-radius: 1.5rem; padding: 2.25rem 1.1rem; }
  @media (min-width: 1024px) { .cat-cmp-box { border-radius: 2rem; padding: 3.5rem 3rem; } }
  .cat-cmp-title { font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.1; letter-spacing: -0.02em; color: #1a1a1a; text-align: center; margin: 0 0 0.9rem; }
  .cat-cmp-sub { font-family: var(--font-sans); font-weight: 600; font-size: clamp(0.95rem, 1.4vw, 1.0625rem); line-height: 1.6; color: #6b7280; text-align: center; max-width: 52rem; margin: 0 auto 2rem; }
  .cat-cmp-tabs { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin: 0 0 1.75rem; }
  .cat-cmp-tab { font-family: var(--font-sans); font-weight: 700; font-size: 0.9375rem; color: #1a1a1a; background: #ffffff; border: 1px solid #ececec; border-radius: 999px; padding: 0.55rem 1.2rem; cursor: pointer; transition: background 200ms ease, color 200ms ease, border-color 200ms ease; }
  @media (hover: hover) { .cat-cmp-tab:hover { border-color: #ff4c00; color: #ff4c00; } }
  .cat-cmp-tab.is-active { background: #ff4c00; border-color: #ff4c00; color: #ffffff; }
  .cat-cmp-panel[hidden] { display: none; }
  .cat-cmp-panel { animation: cat-cmp-fade 360ms ease; }
  @keyframes cat-cmp-fade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .cat-cmp-panel { animation: none; } }
  .cat-cmp-card { background: #ffffff; border: 1px solid #f0e6e0; border-radius: 1.5rem; overflow: hidden; max-width: 50rem; margin: 0 auto; }
  .cat-cmp-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .cat-cmp-table { width: 100%; border-collapse: collapse; min-width: 34rem; }
  .cat-cmp-feat { text-align: left; font-family: var(--font-sans); font-weight: 600; font-size: 0.9375rem; color: #1a1a1a; padding: 1.05rem 1.25rem; }
  .cat-cmp-col { font-family: var(--font-sans); font-weight: 700; font-size: 0.875rem; color: #6b7280; text-align: center; padding: 1.25rem 1rem; white-space: nowrap; vertical-align: middle; }
  .cat-cmp-logo { height: 1.4rem; width: auto; display: inline-block; vertical-align: middle; }
  .cat-cmp-col-kg { background: #fff0e9; }
  .cat-cmp-table tbody tr { border-top: 1px dashed #ececec; }
  .cat-cmp-cell { text-align: center; padding: 1.05rem 1rem; vertical-align: middle; }
  .cat-cmp-mark { display: inline-flex; align-items: center; justify-content: center; width: 1.35rem; height: 1.35rem; }
  .cat-cmp-mark :global(svg) { width: 100%; height: 100%; }
  .cat-cmp-yes { color: #1a1a1a; }
  .cat-cmp-col-kg .cat-cmp-yes { color: #ff4c00; }
  .cat-cmp-no { color: #dadde1; }
  .cat-cmp-partial { color: #c4c8ce; }
  .cat-cmp-sr { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .cat-lineup-thumb img, .cat-shop-base, .cat-shop-weared { transition: none; }
    .cat-shop-card.cat-shop-anim { animation: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Lineup filter — sets active state and filters the product grid
  const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-lineup-item'));
  const shopCards = Array.from(document.querySelectorAll<HTMLElement>('.cat-shop-card'));
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const cat = btn.dataset.filter;
      let vis = 0;
      shopCards.forEach((c) => {
        const show = cat === 'all' || c.dataset.category === cat;
        c.classList.toggle('is-hidden', !show);
        if (show) {
          c.classList.add('in');
          // replay the entrance animation, staggered by visible position
          c.classList.remove('cat-shop-anim');
          void c.offsetWidth;
          c.style.animationDelay = `${vis * 45}ms`;
          c.classList.add('cat-shop-anim');
          vis++;
        }
      });
    });
  });

  // Comparison tabs — switch which alternative is compared against Kustom Garment
  const cmpTabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-cmp-tab'));
  const cmpPanels = Array.from(document.querySelectorAll<HTMLElement>('.cat-cmp-panel'));
  cmpTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.cmp;
      cmpTabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      cmpPanels.forEach((p) => {
        const active = p.dataset.cmpPanel === id;
        p.classList.toggle('is-active', active);
        p.hidden = !active;
      });
    });
  });

  // Color swatches — active state + update the shown color name, per card
  document.querySelectorAll<HTMLElement>('.cat-shop-card').forEach((card) => {
    const nameEl = card.querySelector<HTMLElement>('.cat-shop-color');
    const swatches = Array.from(card.querySelectorAll<HTMLButtonElement>('.cat-shop-swatch'));
    swatches.forEach((sw) => {
      sw.addEventListener('click', () => {
        swatches.forEach((s) => s.classList.remove('is-active'));
        sw.classList.add('is-active');
        if (nameEl && sw.dataset.color) nameEl.textContent = sw.dataset.color;
      });
    });
  });
</script>
