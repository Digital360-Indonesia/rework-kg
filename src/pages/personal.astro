---
import BaseLayout from '../layouts/BaseLayout.astro';
import EndCta from '../components/sections/EndCta.astro';
import pers from '../data/personal.json';

const metaTitle = pers.meta.title;
const metaDescription = pers.meta.description;
// --- CMS-managed (src/data/personal.json — hero + lookbook) ---
const hero = pers.hero;

// Product-type filters (transparent lineup cutouts). 'all' renders a grid icon.
const LU = (name: string) => `/images/placeholder/forproducts/20250428-Business_Line-Up_${name}-r544xqu3jmqddg603jussaip9yxnizaejhckc01cdk.webp`;
const lineupFilters = [
  { id: 'all',    label: 'Semua',  image: '' },
  { id: 'kaos',   label: 'Kaos',   image: LU('Kaos') },
  { id: 'jaket',  label: 'Jaket',  image: LU('Jaket') },
  { id: 'kemeja', label: 'Kemeja', image: LU('Kemeja') },
  { id: 'polo',   label: 'Polo',   image: LU('Polo') },
];

// Color palette (name → hex). SAMPLE.
const C: Record<string, string> = {
  'Putih': '#f4f4f4', 'Hitam': '#1a1a1a', 'Navy': '#1b2a4a', 'Abu': '#9ca3af',
  'Abu Misty': '#b8bcc2', 'Krem': '#e8dcc6', 'Biru Muda': '#bcd3e8', 'Maroon': '#6d1f2f',
  'Olive': '#5b6236', 'Khaki': '#b3a06a', 'Sage': '#b3c2a3',
};
const mk = (names: string[]) => names.map((n) => ({ name: n, hex: C[n] }));

// Product grid (SAMPLE — placeholder shirt photos; swap for real personal product/weared pairs).
const fp = '/images/placeholder/forproducts';
const shopProducts = [
  { name: 'Kaos Custom',   category: 'kaos',   base: `${fp}/p1.jpg`, weared: `${fp}/weared1.jpg`, colors: mk(['Hitam','Putih','Navy','Maroon','Olive']),     more: 14, price: 'Rp 89.000' },
  { name: 'Jaket Harian',  category: 'jaket',  base: `${fp}/p2.jpg`, weared: `${fp}/weared2.jpg`, colors: mk(['Navy','Hitam','Olive','Khaki','Maroon']),     more: 5,  price: 'Rp 219.000' },
  { name: 'Kemeja Custom', category: 'kemeja', base: `${fp}/p3.jpg`, weared: `${fp}/weared3.jpg`, colors: mk(['Putih','Biru Muda','Navy','Abu','Hitam']),    more: 6,  price: 'Rp 165.000' },
  { name: 'Kaos OOTD',     category: 'kaos',   base: `${fp}/p4.jpg`, weared: `${fp}/weared4.jpg`, colors: mk(['Putih','Hitam','Abu Misty','Navy','Krem']),   more: 12, price: 'Rp 95.000' },
  { name: 'Polo Personal', category: 'polo',   base: `${fp}/p5.jpg`, weared: `${fp}/weared5.jpg`, colors: mk(['Navy','Putih','Hitam','Abu','Maroon']),       more: 6,  price: 'Rp 125.000' },
  { name: 'Hoodie Custom', category: 'jaket',  base: `${fp}/p6.jpg`, weared: `${fp}/weared6.jpg`, colors: mk(['Hitam','Navy','Olive','Abu','Maroon']),       more: 7,  price: 'Rp 195.000' },
  { name: 'Kemeja Motif',  category: 'kemeja', base: `${fp}/p7.jpg`, weared: `${fp}/weared7.jpg`, colors: mk(['Biru Muda','Putih','Sage','Abu','Navy']),     more: 5,  price: 'Rp 169.000' },
  { name: 'Kaos Quotes',   category: 'kaos',   base: `${fp}/p8.jpg`, weared: `${fp}/weared8.jpg`, colors: mk(['Hitam','Putih','Krem','Navy','Maroon']),      more: 9,  price: 'Rp 89.000' },
];

// Editorial lookbook gallery (full-bleed) — CMS-managed via src/data/personal.json
const lookbook = pers.lookbook;
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <main class="cat">
    <!-- HERO (full-image lookbook) -->
    <section class="cat-hero is-image">
      <div class="cat-hero-frame">
        {(hero as any).images && (hero as any).images.length
          ? <div class="cat-hero-split">{(hero as any).images.map((src: string) => <img class="cat-hero-bg" src={src} alt={hero.imageAlt} loading="eager" />)}</div>
          : <picture>
              {(hero as any).imageMobile && <source srcset={(hero as any).imageMobile} media="(max-width: 1023px)" />}
              <img class="cat-hero-bg" src={hero.image} alt={hero.imageAlt} loading="eager" />
            </picture>}
        <div class="cat-hero-center">
          <div class="cat-hero-lockup reveal">
            <img class="cat-hero-logo" src="/images/logos/kg-logo.png" alt="Kustom Garment" />
            <span class="cat-hero-tag">{hero.tagline}</span>
          </div>
          <h1 class="cat-hero-big reveal">
            <span>{hero.line1}</span>
            <span>{hero.line2}</span>
          </h1>
        </div>
      </div>
    </section>

    <!-- LOOKBOOK (editorial photo grid) -->
    <section class="cat-look">
      <div class="cat-look-grid">
        {lookbook.map((l) => (
          <div class:list={["cat-look-cell", l.span]}>
            <img src={l.img} alt={l.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </section>

    {/* Product catalog (filter + grid) hidden for personal for now — data/styles kept below for easy restore. */}

    <!-- BANNER (reused homepage end-CTA) closes the page -->
    <EndCta />
  </main>
</BaseLayout>

<style>
  .cat { background: #ffffff; }
  .cat-wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
  @media (min-width: 1024px) { .cat-wrap { padding: 0 2.5rem; } }

  /* HERO (full-image lookbook, framed full-screen with light margins) */
  .cat-hero.is-image { background: #ffffff; padding: 0.6rem 0.6rem 0; }
  @media (min-width: 1024px) { .cat-hero.is-image { padding: 0.85rem 0.85rem 0; } }
  .cat-hero-frame { position: relative; min-height: calc(100svh - 0.6rem); display: grid; place-items: center; overflow: hidden; border-radius: 1.25rem; background: #141414; }
  @media (min-width: 1024px) { .cat-hero-frame { min-height: calc(100svh - 0.85rem); border-radius: 1.5rem; } }
  .cat-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  /* 2-image split hero — each fills half the frame; soft center scrim keeps the white text readable */
  .cat-hero-split { position: absolute; inset: 0; display: grid; grid-template-columns: 1fr 1fr; }
  .cat-hero-split .cat-hero-bg { position: relative; inset: auto; }
  .cat-hero-split::after { content: ''; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 85% 60% at 50% 45%, rgba(0,0,0,.32) 0%, rgba(0,0,0,.14) 46%, rgba(0,0,0,0) 78%); }
  .cat-hero-center { position: relative; z-index: 1; text-align: center; padding: 0 1.5rem; color: #ffffff; }
  /* Header auto-hides over this full-screen hero; peeks on hover-to-top / scroll-up (personal only) */
  :global(#main-header) { position: fixed; left: 0; right: 0; top: 0; transform: translateY(-100%); transition: transform 320ms cubic-bezier(0.19, 1, 0.22, 1); will-change: transform; }
  :global(body.hdr-show #main-header) { transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { :global(#main-header) { transition: none; } }
  .cat-hero-lockup { display: inline-flex; align-items: center; gap: 0.55rem; margin-bottom: 1.1rem; }
  .cat-hero-logo { height: 1.15rem; width: auto; display: block; filter: brightness(0) invert(1); }
  .cat-hero-tag { font-family: Constantia, Georgia, 'Times New Roman', serif; font-weight: 400; font-size: 0.9375rem; letter-spacing: 0.06em; color: rgba(255,255,255,0.92); }
  .cat-hero-big {
    font-family: Constantia, Georgia, 'Times New Roman', serif; font-weight: 400;
    font-size: clamp(3.5rem, 13vw, 9.5rem); line-height: 0.92; letter-spacing: -0.03em;
    color: #ffffff; margin: 0; display: flex; flex-direction: column;
    text-shadow: 0 2px 30px rgba(0,0,0,0.25);
  }

  /* PRODUCT FILTER (lineup) */
  .cat-lineup { padding: 4.5rem 0 0.5rem; }
  @media (min-width: 1024px) { .cat-lineup { padding: 6rem 0 0.5rem; } }
  .cat-lineup-row {
    display: flex; gap: 1.25rem; overflow-x: auto; scroll-snap-type: x proximity;
    scrollbar-width: none; padding-top: 0.5rem; padding-bottom: 0.5rem;
    margin: 0 -1.5rem; padding-left: 1.5rem; padding-right: 1.5rem;
  }
  .cat-lineup-row::-webkit-scrollbar { display: none; }
  @media (min-width: 1024px) { .cat-lineup-row { margin: 0 -2.5rem; padding-left: 2.5rem; padding-right: 2.5rem; justify-content: flex-start; } }
  .cat-lineup-item {
    flex: 0 0 auto; width: 6rem; background: none; border: none; padding: 0; cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 0.55rem; scroll-snap-align: start;
  }
  .cat-lineup-thumb { width: 100%; aspect-ratio: 1 / 1; border-radius: 50%; overflow: hidden; background: #f4f4f4; display: grid; place-items: center; padding: 16%; box-shadow: 0 0 0 2px transparent, 0 0 0 4px transparent; transition: box-shadow 200ms ease; }
  .cat-lineup-thumb img { width: 100%; height: 100%; object-fit: contain; display: block; transition: transform 600ms cubic-bezier(0.19,1,0.22,1); }
  .cat-lineup-all { display: grid; grid-template-columns: 1fr 1fr; gap: 22%; width: 64%; height: 64%; }
  .cat-lineup-all i { background: #c4c4c4; border-radius: 0.2rem; transition: background 200ms ease; }
  .cat-lineup-label { font-family: var(--font-sans); font-weight: 700; font-size: 0.8125rem; color: #6b7280; transition: color 200ms ease; }
  .cat-lineup-item.is-active .cat-lineup-thumb { box-shadow: 0 0 0 2px #fff, 0 0 0 4px #ff4c00; }
  .cat-lineup-item.is-active .cat-lineup-all i { background: #ff4c00; }
  .cat-lineup-item.is-active .cat-lineup-label { color: #1a1a1a; }
  @media (hover: hover) {
    .cat-lineup-item:hover .cat-lineup-thumb img { transform: scale(1.06); }
    .cat-lineup-item:hover .cat-lineup-label { color: #ff4c00; }
  }

  /* PRODUCT GRID */
  @media (min-width: 1024px) { .cat-lineup .cat-wrap, .cat-shop .cat-wrap { max-width: 90rem; } }
  .cat-shop { padding: 2.5rem 0 5rem; }
  @media (min-width: 1024px) { .cat-shop { padding: 3rem 0 7rem; } }
  .cat-shop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem 1.25rem; }
  @media (min-width: 768px) { .cat-shop-grid { grid-template-columns: repeat(3, 1fr); gap: 2.75rem 1.5rem; } }
  @media (min-width: 1024px) { .cat-shop-grid { grid-template-columns: repeat(5, 1fr); } }
  .cat-shop-card { display: block; }
  .cat-shop-card.is-hidden { display: none; }
  .cat-shop-card.cat-shop-anim { animation: cat-shop-pop 460ms cubic-bezier(0.19,1,0.22,1) both; }
  @keyframes cat-shop-pop { from { opacity: 0; transform: translateY(12px) scale(0.985); } to { opacity: 1; transform: none; } }
  .cat-shop-frame { position: relative; border-radius: 1rem; overflow: hidden; aspect-ratio: 3 / 4; background: #f4f4f4; }
  .cat-shop-base, .cat-shop-weared { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 450ms ease; }
  .cat-shop-weared { opacity: 0; }
  @media (hover: hover) {
    .cat-shop-card:hover .cat-shop-base { opacity: 0; }
    .cat-shop-card:hover .cat-shop-weared { opacity: 1; }
  }
  .cat-shop-name { font-family: var(--font-sans); font-weight: 400; font-size: 1.0625rem; line-height: 1.2; letter-spacing: -0.01em; color: #1a1a1a; margin: 0.9rem 0 0; }
  .cat-shop-color { font-family: var(--font-sans); font-weight: 400; font-size: 0.875rem; color: #9ca3af; margin: 0.2rem 0 0; }
  .cat-shop-swatches { display: flex; align-items: center; gap: 0.4rem; margin-top: 0.7rem; }
  .cat-shop-swatch {
    width: 1.5rem; height: 1.2rem; border-radius: 0.3rem; background: var(--sw);
    border: 1px solid rgba(0,0,0,0.12); padding: 0; cursor: pointer;
    box-shadow: 0 0 0 2px #fff, 0 0 0 2px transparent; transition: box-shadow 180ms ease;
  }
  .cat-shop-swatch.is-active { box-shadow: 0 0 0 2px #fff, 0 0 0 3px #9ca3af; }
  .cat-shop-more { font-family: var(--font-sans); font-weight: 600; font-size: 0.8125rem; color: #6b7280; margin-left: 0.2rem; }
  .cat-shop-price { font-family: var(--font-sans); font-size: 0.8125rem; margin: 0.75rem 0 0; }
  .cat-shop-price-pre { font-weight: 400; font-size: 0.8125rem; color: #6b7280; }
  .cat-shop-price-amt { font-weight: 600; color: #ff4c00; }

  /* LOOKBOOK (full-body looks lineup — 2-up mobile, 4-up desktop; full outfit shown) */
  .cat-look { background: #ffffff; padding: clamp(1.5rem,4vw,3.5rem) clamp(0.75rem,2vw,1.75rem) clamp(0.5rem,2vw,1.5rem); }
  .cat-look-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(0.4rem,1.4vw,1rem); max-width: 96rem; margin: 0 auto; }
  @media (min-width: 768px) { .cat-look-grid { grid-template-columns: repeat(4, 1fr); } }
  .cat-look-cell { overflow: hidden; background: #f4f4f4; border-radius: 0.6rem; }
  .cat-look-cell img { width: 100%; height: 100%; object-fit: contain; display: block; transition: transform 600ms cubic-bezier(0.19,1,0.22,1); }
  .cat-look-cell.look { aspect-ratio: 2 / 5; }
  @media (hover:hover) { .cat-look-cell.look:hover img { transform: scale(1.03); } }
  /* legacy big-photo cells (kept for restore): */
  .cat-look-cell.tall { height: 62svh; }
  @media (min-width: 768px) { .cat-look-cell.tall { height: 100svh; } }
  .cat-look-cell.wide { grid-column: 1 / -1; aspect-ratio: 16 / 7; max-height: 90vh; }
  @media (max-width: 640px) { .cat-look-cell.wide { aspect-ratio: 16 / 11; } }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 700ms ease, transform 700ms cubic-bezier(0.19,1,0.22,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .cat-lineup-thumb img, .cat-shop-base, .cat-shop-weared, .cat-look-cell img { transition: none; }
    .cat-shop-card.cat-shop-anim { animation: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Personal: header stays hidden; reveals only when hovering to the very top.
  // Touch devices have no hover, so they fall back to scroll-up for nav access.
  const hoverCapable = window.matchMedia('(hover: hover)').matches;
  let lastY = window.scrollY;
  const syncHeader = (mouseY: number | null) => {
    const y = window.scrollY;
    const up = y < lastY - 2;
    lastY = y;
    const nearTop = mouseY != null && mouseY < 90;
    const show = hoverCapable ? nearTop : (up && y > 60);
    document.body.classList.toggle('hdr-show', show);
  };
  window.addEventListener('mousemove', (e) => syncHeader(e.clientY), { passive: true });
  window.addEventListener('scroll', () => syncHeader(null), { passive: true });
  syncHeader(null);

  // Lineup filter — sets active state and filters the product grid
  const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-lineup-item'));
  const shopCards = Array.from(document.querySelectorAll<HTMLElement>('.cat-shop-card'));
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const cat = btn.dataset.filter;
      let vis = 0;
      shopCards.forEach((c) => {
        const show = cat === 'all' || c.dataset.category === cat;
        c.classList.toggle('is-hidden', !show);
        if (show) {
          c.classList.add('in');
          c.classList.remove('cat-shop-anim');
          void c.offsetWidth;
          c.style.animationDelay = `${vis * 45}ms`;
          c.classList.add('cat-shop-anim');
          vis++;
        }
      });
    });
  });

  // Color swatches — active state + update the shown color name, per card
  document.querySelectorAll<HTMLElement>('.cat-shop-card').forEach((card) => {
    const nameEl = card.querySelector<HTMLElement>('.cat-shop-color');
    const swatches = Array.from(card.querySelectorAll<HTMLButtonElement>('.cat-shop-swatch'));
    swatches.forEach((sw) => {
      sw.addEventListener('click', () => {
        swatches.forEach((s) => s.classList.remove('is-active'));
        sw.classList.add('is-active');
        if (nameEl && sw.dataset.color) nameEl.textContent = sw.dataset.color;
      });
    });
  });
</script>
