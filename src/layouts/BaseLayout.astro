---
/**
 * Base Layout - Kustom Garment
 * Main layout wrapper for all pages
 * Following rework-lg pattern with SEO, structured data, accessibility
 */
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
import siteConfig from '../data/site-config.json';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  canonicalURL?: string;
  noCurtain?: boolean;
  noFooter?: boolean;
}

const {
  title,
  description = siteConfig.description,
  image = '/images/hero/no-min-order-banner.webp',
  noIndex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  canonicalURL,
  noCurtain = false,
  noFooter = false,
} = Astro.props;

// Generate canonical URL
const fullCanonicalURL = canonicalURL
  ? new URL(canonicalURL, siteConfig.siteUrl)
  : new URL(Astro.url.pathname, siteConfig.siteUrl);

// Page type for structured data
const pageType = type === 'article' ? 'article' : 'website';

// WhatsApp from config
const whatsappNumber = siteConfig.contact.whatsapp;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="generator" content={Astro.generator}>

  <!-- SEO Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content={siteConfig.seo.keywords.join(', ')}>
  <link rel="canonical" href={fullCanonicalURL}>

  {noIndex && <meta name="robots" content="noindex, nofollow">}

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={pageType}>
  <meta property="og:url" content={fullCanonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(image, siteConfig.siteUrl)}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content={siteConfig.siteName}>
  <meta property="og:locale" content="id_ID">

  {publishedTime && <meta property="article:published_time" content={publishedTime}>}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime}>}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={fullCanonicalURL}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={new URL(image, siteConfig.siteUrl)}>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="221x221" href="/images/logos/favicon-kg.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/logos/favicon-kg.png">

  <!-- Fonts - Montserrat (Kustom Garment primary font) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="Blog Kustom Garment" href="/blog/rss.xml">

  <!-- Structured Data -->
  <script set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": type === 'article' ? 'BlogPosting' : 'WebPage',
    "name": title,
    "description": description,
    "url": fullCanonicalURL,
    ...(image && {
      "image": new URL(image, siteConfig.siteUrl).toString()
    }),
    "publisher": {
      "@type": "Organization",
      "name": siteConfig.siteName,
      "url": siteConfig.siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": new URL('/images/logos/kg-logo.png', siteConfig.siteUrl)
      },
      "sameAs": [
        siteConfig.social.instagram,
        siteConfig.social.tiktok,
        siteConfig.social.facebook,
        siteConfig.social.youtube
      ]
    },
    ...(type === 'article' && {
      "headline": title,
      "datePublished": publishedTime,
      "dateModified": modifiedTime || publishedTime,
      "author": {
        "@type": "Organization",
        "name": siteConfig.siteName
      }
    })
  })} type="application/ld+json"></script>
</head>

<body class="min-h-screen flex flex-col">
  <!-- Page-transition curtain: orange sweeps up (cover on leave, reveal on enter) -->
  {!noCurtain && <div class="page-curtain" aria-hidden="true"></div>}

  <!-- Skip to main content for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded-lg z-50">
    Skip to main content
  </a>

  <!-- Header / Navigation -->
  <Header currentPath={currentPath} />

  <!-- Main Content -->
  <main id="main-content" class="flex-grow">
    <slot />
  </main>

  <!-- Footer -->
  {!noFooter && <Footer />}

  <!-- Deep-scroll: /?goto=<section-class> jumps to that section (used by /checklist preview links) -->
  <script>
    const _goto = new URLSearchParams(location.search).get('goto');
    if (_goto) {
      const _sel = (window.CSS && CSS.escape) ? CSS.escape(_goto) : _goto;
      const _el = document.querySelector('.' + _sel);
      if (_el) {
        addEventListener('load', () => setTimeout(() => _el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 150));
      }
    }
  </script>

  <!-- Page-transition curtain -->
  <style>
    .page-curtain {
      position: fixed;
      inset: 0;
      background: #ff4c00;
      z-index: 9999;
      pointer-events: none;
      transform: translateY(-100%);
      animation: curtain-in 0.7s cubic-bezier(0.76, 0, 0.24, 1) forwards;
    }
    /* enter: orange covers, then sweeps up & out to reveal the page */
    @keyframes curtain-in {
      0%   { transform: translateY(0); }
      100% { transform: translateY(-100%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .page-curtain { animation: none; transform: translateY(-100%); }
    }
  </style>
  <script>
    // On internal navigation, sweep the orange curtain up to cover, then go.
    const curtain = document.querySelector('.page-curtain');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (curtain && !reduce) {
      document.addEventListener('click', (e) => {
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
        const a = (e.target instanceof Element) ? e.target.closest('a') : null;
        if (!a) return;
        const href = a.getAttribute('href');
        if (!href || a.target === '_blank' || a.hasAttribute('download')) return;
        if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
        let url;
        try { url = new URL(href, location.href); } catch { return; }
        if (url.origin !== location.origin) return;            // external (wa.me, IG, portfolio.) → open normally
        if (url.pathname === location.pathname && url.hash) return; // same-page anchor
        e.preventDefault();
        curtain.style.animation = 'none';
        const anim = curtain.animate(
          [{ transform: 'translateY(100%)' }, { transform: 'translateY(0)' }],
          { duration: 520, easing: 'cubic-bezier(0.76, 0, 0.24, 1)', fill: 'forwards' }
        );
        anim.onfinish = () => { window.location.href = url.href; };
      });
    }

    // bfcache fix: when this page is restored from the back/forward cache, the
    // curtain may have been left covering the screen (orange) from when we
    // navigated away — scripts don't re-run on bfcache restore, so it sticks.
    // On restore, cancel any leftover curtain animation and hide it.
    window.addEventListener('pageshow', (e) => {
      if (!e.persisted || !curtain) return;
      curtain.getAnimations().forEach((a) => a.cancel());
      curtain.style.animation = 'none';
      curtain.style.transform = 'translateY(-100%)';
    });
  </script>
</body>
</html>

<style>
  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .focus\:not-sr-only:focus {
    position: static;
    width: auto;
    height: auto;
    padding: inherit;
    margin: inherit;
    overflow: visible;
    clip: auto;
    white-space: normal;
  }
</style>
