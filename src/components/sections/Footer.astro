---
import siteConfig from '../../data/site-config.json';

const { contact, navigation, social, footer } = siteConfig;
const year = new Date().getFullYear();

const socials = [
  { name: 'TikTok', href: social.tiktok },
  { name: 'Instagram', href: social.instagram },
  { name: 'Facebook', href: 'https://www.facebook.com/kustomgarment' },
];

const miniNav = navigation;
---

<footer class="ft">
  <div class="ft-inner">
    <!-- Tagline -->
    <div class="ft-cta">
      <p class="ft-tagline">{footer.tagline}</p>
    </div>

    <!-- Meta row -->
    <div class="ft-meta">
      <div class="ft-col ft-contact">
        <span class="ft-label">Studio</span>
        <p class="ft-addr">{contact.address}</p>
        <a class="ft-line" href={`tel:${contact.phone}`}>{contact.phoneFormatted}</a>
        <a class="ft-line" href={`mailto:${contact.email}`}>{contact.email}</a>
      </div>

      <nav class="ft-col ft-nav" aria-label="Kategori">
        <span class="ft-label">Kategori</span>
        {miniNav.map((n) => (
          <a class="ft-navlink" href={n.path}>{n.name}</a>
        ))}
      </nav>

      <nav class="ft-col ft-info" aria-label="Info">
        <span class="ft-label">Info</span>
        {footer.infoLinks.map((n) => (
          <a class="ft-navlink" href={n.path}>{n.name}</a>
        ))}
      </nav>

      <div class="ft-col ft-social">
        <span class="ft-label">Sosial</span>
        <div class="ft-social-row">
          {socials.map((s) => (
            <a class="ft-soc" href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.name}>
              {s.name === 'TikTok' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.05-2.82h-3.1v12.4a2.6 2.6 0 1 1-2.6-2.6c.27 0 .53.04.78.12V9.74a5.7 5.7 0 0 0-.78-.05A5.7 5.7 0 1 0 15.55 15V9.01a7.3 7.3 0 0 0 4.45 1.5V7.4a4.28 4.28 0 0 1-3.4-1.58Z"/></svg>
              )}
              {s.name === 'Instagram' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2.5" y="2.5" width="19" height="19" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/></svg>
              )}
              {s.name === 'Facebook' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Giant wordmark: outlined, fills orange on hover -->
  <a class="ft-wordmark" href="/" aria-label="Kustom Garment">KUSTOM GARMENT</a>

  <div class="ft-bottom">
    <span class="ft-legal">© {year}, KUSTOM GARMENT. {footer.legalLine} <a class="ft-legal-link" href={footer.privacyUrl}>{footer.privacyLabel}</a></span>
    <span>{footer.descriptor}</span>
  </div>
</footer>

<style>
  .ft {
    background: #ff4c00;
    color: #ffffff;
    padding: 3rem 0 1.5rem;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .ft { padding: 3.5rem 0 2rem; }
  }
  .ft-inner {
    max-width: 96rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  @media (min-width: 1024px) {
    .ft-inner { padding: 0 2.5rem; }
  }

  /* CTA */
  .ft-cta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.22);
  }
  .ft-tagline {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 3.2vw, 2.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #ffffff;
    max-width: 22ch;
    text-wrap: balance;
  }

  /* Meta */
  .ft-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 2rem 0;
  }
  @media (min-width: 640px) {
    .ft-meta { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .ft-meta { grid-template-columns: 1.5fr 1fr 1.2fr 1fr; }
  }
  .ft-col { display: flex; flex-direction: column; }
  .ft-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 1rem;
  }
  .ft-addr {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 0.75rem;
  }
  .ft-line {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .ft-line:hover { color: #ffffff; text-decoration: underline; }

  .ft-navlink {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    padding: 0.2rem 0;
    width: max-content;
    transition: color 200ms ease, padding-left 200ms ease;
  }
  .ft-navlink:hover { color: #ffffff; padding-left: 0.35rem; }

  .ft-social-row { display: flex; gap: 0.75rem; }
  .ft-soc {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.35);
    transition: background 220ms ease, color 220ms ease, transform 220ms ease, border-color 220ms ease;
  }
  .ft-soc svg { width: 1.3rem; height: 1.3rem; }
  .ft-soc:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #ff4c00;
    transform: translateY(-3px);
  }

  /* Giant wordmark */
  .ft-wordmark {
    display: block;
    margin: 0.5rem 0 1rem;
    padding: 0 1.25rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.5rem, 11vw, 11rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-align: center;
    white-space: nowrap;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 500ms ease, -webkit-text-stroke-color 500ms ease;
  }
  @media (hover: hover) {
    .ft-wordmark:hover {
      color: #ffffff;
      -webkit-text-stroke-color: #ffffff;
    }
  }

  /* Bottom bar */
  .ft-bottom {
    max-width: 96rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.7);
  }
  .ft-legal-link {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ft-legal-link:hover { opacity: 0.75; }
  @media (min-width: 640px) {
    .ft-bottom { flex-direction: row; justify-content: space-between; }
  }
  @media (min-width: 1024px) {
    .ft-bottom { padding-left: 2.5rem; padding-right: 2.5rem; }
  }
</style>
