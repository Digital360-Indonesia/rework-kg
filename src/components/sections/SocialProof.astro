---
// Social wall — content from CMS (src/data/home.json). 3 rows of reels scrolling
// in alternating directions; the loop duplicate is generated in the template.
import home from '../../data/home.json';

type Item = { type: 'video'; src: string; href: string; slow: boolean };
const reel = (code: string, slow = false): Item => ({
  type: 'video',
  src: `/videos/ig-${code}.mp4`,
  href: `https://www.instagram.com/reel/${code}/`,
  slow,
});

const rows: Item[][] = home.social.rows.map((row) =>
  row.map((it: { code: string; slow?: boolean }) => reel(it.code, it.slow === true))
);

const dirs = ['left', 'right', 'left'];
const { headlinePrefix, handle, handleUrl } = home.social;
---

<section class="wall" aria-label="Sosial media Kustom Garment">
  <div class="wall-head">
    <h2 class="wall-title">{headlinePrefix} <a class="wall-handle" href={handleUrl} target="_blank" rel="noopener noreferrer">{handle}</a></h2>
  </div>

  <div class="wall-rows">
    {rows.map((items, ri) => (
      <div class="wall-row" data-dir={dirs[ri]}>
        <div class="wall-track">
          {[...items, ...items].map((it, i) => (
            <a
              class="wall-item"
              href={it.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-hidden={i >= items.length ? 'true' : undefined}
              tabindex={i >= items.length ? -1 : undefined}
            >
              {it.type === 'video' ? (
                <video class="wall-media" muted loop playsinline preload="none" data-video data-slow={it.slow ? 'true' : undefined}>
                  <source src={it.src} type="video/mp4" />
                </video>
              ) : (
                <img class="wall-media" src={it.src} alt="" loading="lazy" />
              )}
              <span class="wall-overlay" aria-hidden="true">
                <span class="wall-ig">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2.5" y="2.5" width="19" height="19" rx="5"/>
                    <circle cx="12" cy="12" r="4.2"/>
                    <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/>
                  </svg>
                </span>
              </span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .wall {
    background: #ffffff;
    padding: 4rem 0 5rem;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .wall { padding: 6rem 0 7rem; }
  }

  .wall-head {
    max-width: 96rem;
    margin: 0 auto 2.5rem;
    padding: 0 1.25rem;
  }
  @media (min-width: 1024px) {
    .wall-head { padding: 0 2.5rem; margin-bottom: 3.5rem; }
  }
  .wall-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0;
  }
  .wall-handle {
    color: #ff4c00;
    text-decoration: none;
    white-space: nowrap;
  }
  @media (hover: hover) {
    .wall-handle:hover {
      animation: handle-flicker 2s linear infinite;
    }
  }
  @keyframes handle-flicker {
    0%   { opacity: 1;   text-shadow: 0 0 6px rgba(255,76,0,.6), 0 0 16px rgba(255,76,0,.35); }
    7%   { opacity: .55; text-shadow: none; }
    9%   { opacity: 1;   text-shadow: 0 0 7px rgba(255,76,0,.65), 0 0 18px rgba(255,76,0,.4); }
    23%  { opacity: 1; }
    25%  { opacity: .7;  text-shadow: 0 0 3px rgba(255,76,0,.4); }
    27%  { opacity: 1;   text-shadow: 0 0 9px rgba(255,76,0,.7), 0 0 22px rgba(255,76,0,.45); }
    54%  { opacity: 1; }
    56%  { opacity: .6;  text-shadow: none; }
    58%  { opacity: 1;   text-shadow: 0 0 7px rgba(255,76,0,.6), 0 0 18px rgba(255,76,0,.4); }
    100% { opacity: 1;   text-shadow: 0 0 8px rgba(255,76,0,.6), 0 0 20px rgba(255,76,0,.4); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wall-handle:hover { animation: none; text-shadow: 0 0 8px rgba(255,76,0,.5); }
  }

  .wall-rows {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wall-row {
    overflow: hidden;
  }
  .wall-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    will-change: transform;
  }
  .wall-row[data-dir='left'] .wall-track {
    animation: wall-left 46s linear infinite;
  }
  .wall-row[data-dir='right'] .wall-track {
    animation: wall-right 46s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .wall-track { animation: none !important; }
  }
  /* Pause the marquee while the wall is off-screen (e.g. user is up at the hero) to stop constant compositing */
  .wall.is-offscreen .wall-track { animation-play-state: paused; }

  @keyframes wall-left {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - 0.5rem)); }
  }
  @keyframes wall-right {
    from { transform: translateX(calc(-50% - 0.5rem)); }
    to   { transform: translateX(0); }
  }

  .wall-item {
    position: relative;
    flex: 0 0 auto;
    width: 11rem;
    aspect-ratio: 4 / 5;
    border-radius: 1rem;
    overflow: hidden;
    background: #f4f4f4;
    display: block;
  }
  @media (min-width: 768px) {
    .wall-item { width: 13.5rem; }
  }
  .wall-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wall-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: rgba(10, 10, 10, 0);
    transition: background 300ms ease;
  }
  .wall-ig {
    color: #ffffff;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 300ms ease, transform 360ms cubic-bezier(0.19, 1, 0.22, 1);
  }
  .wall-ig svg { width: 2.25rem; height: 2.25rem; }

  @media (hover: hover) {
    .wall-item:hover .wall-overlay { background: rgba(10, 10, 10, 0.45); }
    .wall-item:hover .wall-ig { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  // Autoplay videos only while in view; pause off-screen to save resources.
  const vids = document.querySelectorAll<HTMLVideoElement>('.wall [data-video]');
  if (vids.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const v = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          if (v.dataset.slow !== undefined) v.playbackRate = 0.8;
          v.play().catch(() => {});
        } else v.pause();
      });
    }, { threshold: 0.2 });
    vids.forEach((v) => {
      if (v.dataset.slow !== undefined) v.playbackRate = 0.8;
      io.observe(v);
    });
  }

  // Pause the marquee animation entirely while the wall is off-screen — stops the
  // 3 tracks from compositing nonstop (the main "lag on the homepage" cost).
  const wall = document.querySelector<HTMLElement>('.wall');
  if (wall) {
    wall.classList.add('is-offscreen'); // start paused; resume when scrolled into view
    const sectionIO = new IntersectionObserver((entries) => {
      entries.forEach((e) => wall.classList.toggle('is-offscreen', !e.isIntersecting));
    }, { rootMargin: '200px 0px' });
    sectionIO.observe(wall);
  }
</script>
