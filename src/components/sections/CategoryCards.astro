---
import home from '../../data/home.json';
const categories = home.categoryCards.items;
const hoverImage = home.categoryCards.hoverImage;
---

<section class="cats" aria-label="Kategori produk">
  <div class="cats-wrap">
    <div class="cats-row">
      {categories.map((c) => (
        <a href={c.href} class="cat">
          <div class="cat-frame">
            <img src={c.image} alt={c.label} loading="lazy" class="cat-img cat-img-base" />
            <img src={c.hoverImage || hoverImage} alt="" aria-hidden="true" loading="lazy" class="cat-img cat-img-hover" />
          </div>
          <span class="cat-label">{c.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cats {
    background: #ffffff;
    padding: 3rem 0 3.5rem;
  }
  @media (min-width: 1024px) {
    .cats { padding: 4rem 0 4.5rem; }
  }

  .cats-wrap {
    max-width: 96rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 1024px) {
    .cats-wrap { padding: 0 1.5rem; }
  }

  .cats-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 2.5rem;
  }
  @media (max-width: 1024px) {
    .cats-row {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 1.5rem;
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .cats-row::-webkit-scrollbar { display: none; }
  }

  .cat {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  @media (max-width: 1024px) {
    .cat {
      scroll-snap-align: start;
      flex: 0 0 auto;
      width: 13rem;
    }
  }
  @media (max-width: 640px) {
    .cat { width: 10.5rem; }
  }

  .cat-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #f4f4f4;
    border-radius: 1.25rem;
    overflow: hidden;
    transition: transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 320ms ease;
  }
  .cat-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cat-img-base {
    z-index: 1;
  }
  .cat-img-hover {
    z-index: 2;
    transform: translateY(-100%);
    transition: transform 820ms cubic-bezier(0.19, 1, 0.22, 1);
    will-change: transform;
  }

  .cat-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1a1a1a;
    text-align: center;
    transition: color 200ms ease;
  }
  @media (min-width: 1024px) {
    .cat-label { font-size: 1rem; }
  }

  /* Hover (desktop only) */
  @media (hover: hover) {
    .cat:hover .cat-frame {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px -20px rgba(15, 15, 20, 0.18);
    }
    .cat:hover .cat-img-hover {
      transform: translateY(0);
    }
    .cat:hover .cat-label {
      color: #ff4c00;
    }
  }
</style>
