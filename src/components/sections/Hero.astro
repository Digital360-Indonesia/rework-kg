---
import home from '../../data/home.json';

const slides = home.hero.slides;
const DURATION_MS = 5000;
---

<section class="hero">
  <div class="hero-wrap">
    <div
      class="hero-slider"
      data-slides={slides.length}
      data-duration={DURATION_MS}
      role="region"
      aria-roledescription="carousel"
      aria-label="Promo utama"
    >
      <!-- Progress bars (story-style) -->
      <div class="bars">
        {slides.map((_, i) => (
          <button
            type="button"
            class:list={['bar', i === 0 && 'is-current']}
            data-jump={i}
            aria-label={`Slide ${i + 1}`}
          >
            <span class="bar-fill"></span>
          </button>
        ))}
      </div>

      <!-- Slides -->
      <div class="slides">
        {slides.map((s, i) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={['slide', i === 0 && 'is-active']}
            data-index={i}
          >
            <picture>
              {(s as any).imageMobile && <source srcset={(s as any).imageMobile} media="(max-width: 1023px)" />}
              <img src={s.image} alt={s.alt} class="slide-img" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} />
            </picture>
          </a>
        ))}
      </div>

      <!-- Edge zones — reveal arrow only on left/right edge hover -->
      <div class="edge-zone edge-zone-prev">
        <button type="button" class="edge edge-prev" aria-label="Slide sebelumnya">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
      </div>
      <div class="edge-zone edge-zone-next">
        <button type="button" class="edge edge-next" aria-label="Slide berikutnya">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: #ffffff;
    padding: 0.75rem 0 1.25rem;
  }
  .hero-wrap {
    max-width: 96rem;
    margin: 0 auto;
    padding: 0 0.75rem;
  }
  @media (min-width: 1024px) {
    .hero-wrap { padding: 0 1rem; }
    .hero { padding: 1rem 0 1.5rem; }
  }

  .hero-slider {
    position: relative;
    aspect-ratio: 16 / 7.15;
    border-radius: 1.75rem;
    overflow: hidden;
    background: #0a0a0a;
    box-shadow: 0 30px 60px -20px rgba(15, 15, 20, 0.18), 0 8px 20px -8px rgba(15, 15, 20, 0.12);
    isolation: isolate;
  }
  @media (max-width: 640px) {
    .hero-slider {
      aspect-ratio: 4 / 5;
      border-radius: 1.25rem;
    }
  }

  /* Progress bars */
  /* Story indicator — dots + expanding fill-pill (active), bottom-centered */
  .bars {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .bar {
    flex: 0 0 auto;
    position: relative;
    width: 7px;
    height: 7px;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 999px;
    overflow: hidden;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: width 0.45s cubic-bezier(0.19, 1, 0.22, 1), background 0.3s ease;
  }
  .bar.is-current { width: 2.4rem; background: rgba(255, 255, 255, 0.35); }
  .bar-fill {
    display: block;
    width: 0%;
    height: 100%;
    background: #ffffff;
    border-radius: 999px;
    transition: none;
  }
  .bar.is-done .bar-fill { width: 100%; }

  /* Slides */
  .slides {
    position: absolute;
    inset: 0;
  }
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease;
    text-decoration: none;
    color: inherit;
  }
  .slide.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 10;
  }
  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Edge nav — glass arrow, revealed only on left/right edge-zone hover */
  .edge-zone {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 18%;
    min-width: 3.5rem;
    z-index: 20;
    display: grid;
    align-items: center;
  }
  .edge-zone-prev { left: 0; justify-items: start; padding-left: 1rem; }
  .edge-zone-next { right: 0; justify-items: end; padding-right: 1rem; }
  .edge {
    position: static;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #ffffff;
    display: grid;
    place-items: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 200ms ease, background 200ms ease, transform 200ms ease;
  }
  .edge svg { width: 0.9rem; height: 0.9rem; }
  @media (hover: hover) { .edge-zone:hover .edge { opacity: 1; } }
  .edge:focus-visible { opacity: 1; }
  .edge:hover {
    background: rgba(255, 255, 255, 0.28);
    transform: scale(1.06);
  }
  @media (max-width: 640px) {
    .edge-zone { display: none; }
  }
</style>

<script>
  const sliders = document.querySelectorAll<HTMLElement>('.hero-slider');

  sliders.forEach((slider) => {
    const count = Number(slider.dataset.slides);
    const duration = Number(slider.dataset.duration) || 5000;
    const slides = slider.querySelectorAll<HTMLElement>('.slide');
    const bars = slider.querySelectorAll<HTMLElement>('.bar');
    const fills = slider.querySelectorAll<HTMLElement>('.bar-fill');
    const prev = slider.querySelector<HTMLElement>('.edge-prev');
    const next = slider.querySelector<HTMLElement>('.edge-next');

    let current = 0;
    let startTs = 0;
    let elapsedBeforePause = 0;
    let raf: number | null = null;
    let paused = false;

    const setActive = (i: number) => {
      slides.forEach((s, idx) => s.classList.toggle('is-active', idx === i));
      bars.forEach((b, idx) => {
        b.classList.toggle('is-done', idx < i);
        b.classList.toggle('is-current', idx === i);
        const f = fills[idx];
        if (idx < i) f.style.width = '100%';
        else if (idx > i) f.style.width = '0%';
      });
      current = i;
      elapsedBeforePause = 0;
      startTs = 0;
    };

    const tick = (ts: number) => {
      if (paused) return;
      if (!startTs) startTs = ts;
      const elapsed = elapsedBeforePause + (ts - startTs);
      const pct = Math.min(elapsed / duration, 1);
      fills[current].style.width = `${pct * 100}%`;
      if (pct >= 1) {
        setActive((current + 1) % count);
      }
      raf = requestAnimationFrame(tick);
    };

    const start = () => { if (raf == null) raf = requestAnimationFrame(tick); };
    const stop = () => { if (raf != null) { cancelAnimationFrame(raf); raf = null; } };

    const pause = () => {
      if (paused || !startTs) return;
      paused = true;
      elapsedBeforePause += performance.now() - startTs;
      startTs = 0;
      stop();
    };
    const resume = () => {
      if (!paused) return;
      paused = false;
      start();
    };

    bars.forEach((bar) => {
      bar.addEventListener('click', (e) => {
        e.stopPropagation();
        const idx = Number(bar.dataset.jump);
        setActive(idx);
      });
    });

    prev?.addEventListener('click', (e) => {
      e.stopPropagation();
      e.preventDefault();
      setActive((current - 1 + count) % count);
    });
    next?.addEventListener('click', (e) => {
      e.stopPropagation();
      e.preventDefault();
      setActive((current + 1) % count);
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => entry.isIntersecting ? resume() : pause());
    }, { threshold: 0.25 });
    io.observe(slider);

    start();
  });
</script>
