---
import home from '../../data/home.json';
const { title, ctaText, bg, bgHover, waText } = home.endCta;
const wa = 'https://wa.me/6285117049918?text=' + encodeURIComponent(waText);
---

<section class="endcta">
  <div class="endcta-wrap">
    <a class="endcta-banner" href={wa} target="_blank" rel="noopener noreferrer" aria-label="Mulai bikin baju custom">
      <img class="endcta-bg endcta-bg-base" src={bg} alt="" />
      <img class="endcta-bg endcta-bg-hover" src={bgHover} alt="" aria-hidden="true" />
      <div class="endcta-scrim" aria-hidden="true"></div>
      <div class="endcta-content">
        <h2 class="endcta-title">{title}</h2>
        <span class="endcta-cta">
          {ctaText} <span class="endcta-arrow" aria-hidden="true">→</span>
        </span>
      </div>
    </a>
  </div>
</section>

<style>
  .endcta {
    background: #ffffff;
    padding: 1.5rem 0 3rem;
  }
  @media (min-width: 1024px) { .endcta { padding: 2rem 0 4rem; } }

  .endcta-wrap {
    max-width: 96rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media (min-width: 1024px) { .endcta-wrap { padding: 0 1.5rem; } }

  .endcta-banner {
    position: relative;
    display: block;
    border-radius: 1.75rem;
    overflow: hidden;
    aspect-ratio: 16 / 5;
    background: #f4f4f4;
    text-decoration: none;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
  @media (max-width: 640px) {
    .endcta-banner { aspect-ratio: 3 / 4; border-radius: 1.25rem; }
  }

  .endcta-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    display: block;
  }
  /* Crossfade: hover image sits on top, fades in on hover */
  .endcta-bg-hover {
    opacity: 0;
    transition: opacity 600ms ease;
  }
  @media (hover: hover) {
    .endcta-banner:hover .endcta-bg-hover { opacity: 1; }
  }

  /* Soft white scrim on the left so dark copy stays legible over the art */
  .endcta-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.6) 32%, rgba(255,255,255,0) 60%);
    pointer-events: none;
  }
  @media (max-width: 640px) {
    .endcta-scrim {
      background: linear-gradient(180deg, rgba(255,255,255,0.94) 0%, rgba(255,255,255,0.65) 38%, rgba(255,255,255,0) 70%);
    }
  }

  .endcta-content {
    position: absolute;
    top: 50%;
    left: 2rem;
    right: 2rem;
    transform: translateY(-50%);
    max-width: 30rem;
  }
  @media (min-width: 768px) { .endcta-content { left: 3.5rem; } }
  @media (max-width: 640px) {
    .endcta-content { top: 2rem; transform: none; left: 1.5rem; right: 1.5rem; }
  }

  .endcta-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0 0 1.25rem;
  }
  .endcta-cta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    position: relative;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    color: #1a1a1a;
    padding-bottom: 0.15em;
  }
  .endcta-cta::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    width: 100%; height: 2.5px;
    background: #ff4c00;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 460ms cubic-bezier(0.19, 1, 0.22, 1);
  }
  .endcta-arrow {
    color: #ff4c00;
    display: inline-block;
    transition: transform 320ms cubic-bezier(0.19, 1, 0.22, 1);
  }
  @media (hover: hover) {
    .endcta-banner:hover .endcta-cta::after { transform: scaleX(1); }
    .endcta-banner:hover .endcta-arrow { transform: translateX(6px); }
  }
</style>
